# Godot 4+ specific ignores
.godot/
.nomedia

# Godot-specific ignores
.import/
export.cfg
export_credentials.cfg

# Godot import sidecar files (auto-generated next to assets)
*.import

# Imported translations (automatically generated from CSV files)
*.translation

# Mono-specific ignores
.mono/
data_*/
mono_crash.*.json

# Claude Code (local only — do not commit)
.claude/

# Godot auto-generated UID files
*.uid

# macOS metadata
.DS_Store

# Blog posts (local only)
blog/

# Python
__pycache__/
*.py[cod]
.venv/

# Blender working/backup files
*.blend1
asset_generation/python/animated_exports/*.blend
asset_generation/python/exports/*.blend
# Session blog queue — auto-generated by post-commit hook, cleared after push
.blog-session.log
