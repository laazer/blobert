# Add the repo root, bin/, and ci/scripts to PATH
# bin/godot — headless Godot wrapper (just type `godot` instead of `Godot --headless`)
# ci/scripts — run_tests.sh and other CI helpers
export PATH="$PWD/bin:$PWD/ci/scripts:$PWD:$PATH"

# Add Godot engine binary to PATH (for direct access to the real binary if needed)
export PATH="/Applications/Godot.app/Contents/MacOS:$PATH"