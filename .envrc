# Headless Godot wrapper + CI helpers (see CLAUDE.md).
export PATH="$PWD/bin:$PWD/ci/scripts:$PWD:$PATH"

# asset_generation/python — uv project (requires-python >=3.11).
# UV_PROJECT lets `uv run …` work from the repo root without `cd`.
export UV_PROJECT="$PWD/asset_generation/python"
watch_file asset_generation/python/uv.lock
watch_file asset_generation/python/pyproject.toml

# After: cd asset_generation/python && uv sync --extra dev
# …`python`, `pytest`, and `ruff` on PATH match the project venv.
if [[ -d "$UV_PROJECT/.venv" ]]; then
  export VIRTUAL_ENV="$UV_PROJECT/.venv"
  PATH_add "$VIRTUAL_ENV/bin"
fi
