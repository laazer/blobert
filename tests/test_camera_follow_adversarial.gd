# EPSILON for floating-point comparisons (project-wide constant).
# ---------------------------------------------------------------------------
const EPSILON: float = 1e-4

# GDScript's maximum safe integer for @export var: int is 64-bit signed.
# However Godot's Camera2D.limit_* properties are 32-bit signed integers
# internally. We test with 2^31 - 1 = 2147483647 (INT32_MAX) and
# -(2^31) = -2147483648 (INT32_MIN) as the platform boundary values.
# CHECKPOINT: Godot 4 Camera2D limit_* may or may not silently clamp
# values exceeding int32 range. The test asserts the assigned value is
# reflected back verbatim from the @export int field (not the Camera2D
# internal property), which is always safe for GDScript int64.
const INT32_MAX: int = 2147483647
const INT32_MIN: int = -2147483648

var _pass_count: int = 0
var _fail_count: int = 0


