# F-04: Modify all twelve export vars between two _ready() calls; verify all twelve
# Camera2D properties reflect the second set of values after the second call.
# Target flaw: if _ready() hardcodes any of the twelve values instead of reading
# from export vars, that property will fail to update on the second call.
func test_f04_change_all_twelve_vars_between_ready_calls_all_override() -> void:
	var node: CameraFollow = CameraFollow.new()
	# First call with defaults.
	node._ready()
	# Change every export var to a non-default value.
	node.smoothing_enabled = false
	node.smoothing_speed = 8.0
	node.drag_horizontal = false
	node.drag_vertical = true
	node.drag_left_margin = 0.1
	node.drag_right_margin = 0.3
	node.drag_top_margin = 0.15
	node.drag_bottom_margin = 0.25
	node.limit_left = -500
	node.limit_right = 500
	node.limit_top = -300
	node.limit_bottom = 300
	# Second call must apply all new values.
	node._ready()
	_assert_false(node.position_smoothing_enabled,
		"F-04a — second _ready(): smoothing_enabled=false → position_smoothing_enabled false")
	_assert_approx(node.position_smoothing_speed, 8.0,
		"F-04b — second _ready(): smoothing_speed=8.0 applied")
	_assert_false(node.drag_horizontal_enabled,
		"F-04c — second _ready(): drag_horizontal=false applied")
	_assert_true(node.drag_vertical_enabled == true,
		"F-04d — second _ready(): drag_vertical=true applied")
	_assert_approx(node.drag_left_margin, 0.1,
		"F-04e — second _ready(): drag_left_margin=0.1 applied")
	_assert_approx(node.drag_right_margin, 0.3,
		"F-04f — second _ready(): drag_right_margin=0.3 applied")
	_assert_approx(node.drag_top_margin, 0.15,
		"F-04g — second _ready(): drag_top_margin=0.15 applied")
	_assert_approx(node.drag_bottom_margin, 0.25,
		"F-04h — second _ready(): drag_bottom_margin=0.25 applied")
	_assert_int_eq(node.limit_left, -500,
		"F-04i — second _ready(): limit_left=-500 applied")
	_assert_int_eq(node.limit_right, 500,
		"F-04j — second _ready(): limit_right=500 applied")
	_assert_int_eq(node.limit_top, -300,
		"F-04k — second _ready(): limit_top=-300 applied")
	_assert_int_eq(node.limit_bottom, 300,
		"F-04l — second _ready(): limit_bottom=300 applied")
	node.free()


