# GROUP F: Idempotency and override — _ready() called multiple times (SPEC-39)
# ===========================================================================
# The primary suite has one idempotency test (test_determinism_calling_ready_twice_is_idempotent)
# but only checks position_smoothing_speed with default values.
# These tests probe: (a) every property is idempotent at defaults, (b) changing
# export vars between calls produces updated Camera2D properties on the second call.

# F-01: Double _ready() with all-default export vars — all twelve Camera2D
# properties must be identical after the second call as after the first.
# Target flaw: an implementation that has any internal state in _ready() that
# is consumed on the first call (e.g., a "has_initialized" guard variable)
# would fail on the second call.
func test_f01_double_ready_all_defaults_all_twelve_properties_stable() -> void:
	var node: CameraFollow = CameraFollow.new()
	node._ready()
	var se1: bool = node.position_smoothing_enabled
	var ss1: float = node.position_smoothing_speed
	var dh1: bool = node.drag_horizontal_enabled
	var dv1: bool = node.drag_vertical_enabled
	var dlm1: float = node.drag_left_margin
	var drm1: float = node.drag_right_margin
	var dtm1: float = node.drag_top_margin
	var dbm1: float = node.drag_bottom_margin
	var ll1: int = node.limit_left
	var lr1: int = node.limit_right
	var lt1: int = node.limit_top
	var lb1: int = node.limit_bottom
	# Second call.
	node._ready()
	_assert_true(node.position_smoothing_enabled == se1,
		"F-01a — double _ready() defaults: position_smoothing_enabled stable")
	_assert_approx(node.position_smoothing_speed, ss1,
		"F-01b — double _ready() defaults: position_smoothing_speed stable")
	_assert_true(node.drag_horizontal_enabled == dh1,
		"F-01c — double _ready() defaults: drag_horizontal_enabled stable")
	_assert_true(node.drag_vertical_enabled == dv1,
		"F-01d — double _ready() defaults: drag_vertical_enabled stable")
	_assert_approx(node.drag_left_margin, dlm1,
		"F-01e — double _ready() defaults: drag_left_margin stable")
	_assert_approx(node.drag_right_margin, drm1,
		"F-01f — double _ready() defaults: drag_right_margin stable")
	_assert_approx(node.drag_top_margin, dtm1,
		"F-01g — double _ready() defaults: drag_top_margin stable")
	_assert_approx(node.drag_bottom_margin, dbm1,
		"F-01h — double _ready() defaults: drag_bottom_margin stable")
	_assert_int_eq(node.limit_left, ll1,
		"F-01i — double _ready() defaults: limit_left stable")
	_assert_int_eq(node.limit_right, lr1,
		"F-01j — double _ready() defaults: limit_right stable")
	_assert_int_eq(node.limit_top, lt1,
		"F-01k — double _ready() defaults: limit_top stable")
	_assert_int_eq(node.limit_bottom, lb1,
		"F-01l — double _ready() defaults: limit_bottom stable")
	node.free()


# F-02: Modify smoothing_speed between two _ready() calls — second call applies
# the NEW value. This tests that _ready() reads the live export var, not a cached
# value set during the first call.
func test_f02_change_smoothing_speed_between_ready_calls_second_overrides() -> void:
