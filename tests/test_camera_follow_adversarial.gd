func run_all() -> int:
	print("--- test_camera_follow_adversarial.gd ---")
	_pass_count = 0
	_fail_count = 0

	# GROUP A: smoothing_speed edge-case values
	test_a01_smoothing_speed_zero_applied_by_ready()
	test_a02_smoothing_speed_zero_export_var_readable()
	test_a03_smoothing_speed_negative_export_var_stored()
	test_a04_smoothing_speed_negative_assigned_by_ready()
	test_a05_smoothing_speed_inf_export_var_stored()
	test_a06_smoothing_speed_inf_assigned_by_ready()
	test_a07_smoothing_speed_very_large_finite_applied_by_ready()

	# GROUP B: smoothing_enabled = false path
	test_b01_smoothing_disabled_path_sets_property_false()
	test_b02_smoothing_disabled_idempotent_double_ready()
	test_b03_second_ready_with_false_overrides_first_ready_true()
	test_b04_second_ready_with_true_overrides_first_ready_false()

	# GROUP C: drag_horizontal and drag_vertical toggles
	test_c01_drag_horizontal_false_applied_by_ready()
	test_c02_drag_vertical_true_applied_by_ready()
	test_c03_both_drag_bools_nondefa_applied_by_ready()

	# GROUP D: drag margin edge-case values
	test_d01_all_drag_margins_zero_applied_by_ready()
	test_d02_all_drag_margins_one_applied_by_ready()
