# ===========================================================================
# GROUP J: Structural / class integrity under adversarial instantiation
# ===========================================================================
# These tests verify that the class behaves correctly when properties are
# accessed in unusual orders, or when the node is freed before _ready() is called.

# J-01: Instantiate, free without calling _ready() — should not crash.
# Target flaw: a _ready() implementation that allocates resources in _init()
# that require cleanup would leak if _ready() is never called before free().
func test_j01_free_without_calling_ready_does_not_crash() -> void:
	var node: CameraFollow = CameraFollow.new()
	# Set a few properties to ensure the node is not in a trivial default state.
	node.smoothing_speed = 0.0
	node.limit_right = 500
	# Free without _ready() — the test passes if no crash occurs.
	node.free()
	_pass("J-01 — CameraFollow can be freed without calling _ready() (no crash)")


# J-02: Export vars readable immediately after instantiation, before _ready().
# Verifies that the @export defaults are available synchronously after .new().
func test_j02_all_export_vars_readable_pre_ready() -> void:
	var node: CameraFollow = CameraFollow.new()
	# This test will fail if any @export var is not initialized until _ready() runs.
	var _se: bool = node.smoothing_enabled
	var _ss: float = node.smoothing_speed
	var _dh: bool = node.drag_horizontal
	var _dv: bool = node.drag_vertical
	var _dlm: float = node.drag_left_margin
	var _drm: float = node.drag_right_margin
	var _dtm: float = node.drag_top_margin
	var _dbm: float = node.drag_bottom_margin
	var _ll: int = node.limit_left
	var _lr: int = node.limit_right
	var _lt: int = node.limit_top
	var _lb: int = node.limit_bottom
	# If we reach this point, all twelve vars were accessible without crash.
	_pass("J-02 — all twelve @export vars readable pre-_ready() without crash")
	node.free()


# J-03: Two separate instances modified independently do not share state.
# Mutation testing: confirms there is no class-level static state that would
# cause instance A's property changes to leak into instance B.
func test_j03_two_instances_do_not_share_export_var_state() -> void:
	var node_a: CameraFollow = CameraFollow.new()
	var node_b: CameraFollow = CameraFollow.new()
	node_a.smoothing_speed = 1.0
	node_b.smoothing_speed = 9.0
	node_a._ready()
	node_b._ready()
	_assert_approx(node_a.position_smoothing_speed, 1.0,
		"J-03a — instance A: smoothing_speed=1.0 applied independently")
	_assert_approx(node_b.position_smoothing_speed, 9.0,
		"J-03b — instance B: smoothing_speed=9.0 applied independently (no state leakage from A)")
	node_a.free()
	node_b.free()


# J-04: Three _ready() calls — property values match current export vars throughout.
# Stresses the idempotency guarantee beyond two calls.
func test_j04_triple_ready_call_idempotent() -> void:
	var node: CameraFollow = CameraFollow.new()
	node.smoothing_speed = 3.0
	node._ready()
	node._ready()
	node._ready()
	_assert_approx(node.position_smoothing_speed, 3.0,
		"J-04 — three consecutive _ready() calls: position_smoothing_speed stable at 3.0")
	node.free()


