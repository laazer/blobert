# ===========================================================================
# GAP-01: Detach on same frame as jump — all fields verified independently
# ===========================================================================
# Vulnerability: the primary suite (test_order_of_ops_jump_and_detach_same_frame)
# checks velocity.y and has_chunk and jump_consumed, but does not independently
# verify all 7 fields to ensure the jump+detach interaction leaves no field
# in a corrupted or default-reverted state. An implementation bug that
# re-initializes result in the detach step could silently zero other fields.

func test_gap01_detach_and_jump_same_frame_all_7_fields() -> void:
	# CHECKPOINT: see [M1-005] Test Breaker — TB-CD-001
	var sim: MovementSimulation = MovementSimulation.new()
	var prior: MovementSimulation.MovementState = _make_state(30.0, 0.0, true)
	prior.has_chunk = true
	prior.jump_consumed = false
	prior.coyote_timer = 0.0
	prior.is_wall_clinging = false
	prior.cling_timer = 0.0

	# Both jump and detach fire on this frame
	var result: MovementSimulation.MovementState = sim.simulate(
		prior, 1.0, true, true, false, 0.0, true, 0.016)

	# has_chunk must be false (detach fired)
	_assert_false(result.has_chunk,
		"gap01 — jump+detach same frame: has_chunk=false")

	# jump_consumed must be true (jump fired)
	_assert_true(result.jump_consumed == true,
		"gap01 — jump+detach same frame: jump_consumed=true")

	# velocity.y must reflect jump impulse (not gravity-only, not zero)
	# jump_impulse = -sqrt(2 * gravity * jump_height) + gravity * delta
	var expected_vy: float = -sqrt(2.0 * 980.0 * 120.0) + 980.0 * 0.016
	_assert_approx(result.velocity.y, expected_vy,
		"gap01 — jump+detach same frame: velocity.y is jump impulse")

	# velocity.x must reflect horizontal movement (input_axis=1.0, grounded)
	# move_toward(30.0, 200.0, 800.0 * 0.016) = move_toward(30, 200, 12.8) = 42.8
	_assert_approx(result.velocity.x, 42.8,
		"gap01 — jump+detach same frame: velocity.x uses acceleration")

	# is_on_floor must be passed through from the prior call (true on this frame)
	_assert_true(result.is_on_floor == true,
		"gap01 — jump+detach same frame: is_on_floor passes through (true)")

	# coyote_timer: on floor → reset to coyote_time (timer resets when grounded)
	# Implementation: coyote_timer is reset to 0 when on floor and jump fires.
	# When on floor, coyote_timer is typically 0 or reset. We just verify it is
	# a non-negative finite value (no corruption).
	_assert_true(result.coyote_timer >= 0.0,
		"gap01 — jump+detach same frame: coyote_timer non-negative (no corruption)")

	# is_wall_clinging must remain false (not on a wall)
	_assert_false(result.is_wall_clinging,
		"gap01 — jump+detach same frame: is_wall_clinging stays false")

	# cling_timer must remain 0.0 (no cling active)
	_assert_approx(result.cling_timer, 0.0,
		"gap01 — jump+detach same frame: cling_timer stays 0.0")


