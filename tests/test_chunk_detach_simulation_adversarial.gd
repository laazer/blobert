# ===========================================================================
# GAP-04: Rapid repeated detach — stable no-op when has_chunk=false
# ===========================================================================
# Vulnerability: spec says detach_just_pressed=true with has_chunk=false is a
# no-op. A faulty implementation might have a mutable flag or counter that
# drifts when called repeatedly. Five consecutive no-op detach calls must
# leave result.has_chunk=false every time without side effects.

func test_gap04_rapid_detach_noop_five_consecutive_calls() -> void:
	# CHECKPOINT: see [M1-005] Test Breaker — TB-CD-004
	var sim: MovementSimulation = MovementSimulation.new()
	var state: MovementSimulation.MovementState = _make_default_state()
	state.has_chunk = false  # already detached

	var i: int = 0
	while i < 5:
		state = sim.simulate(state, 0.0, false, false, false, 0.0, true, 0.016)
		_assert_false(state.has_chunk,
			"gap04 — rapid no-op detach call " + str(i + 1) + ": has_chunk stays false")
		i += 1


func test_gap04_rapid_detach_noop_no_velocity_drift() -> void:
	# Repeated no-op detach calls must not drift velocity.
	# Without any horizontal input, gravity accumulates — verify it is normal gravity,
	# not doubled or otherwise corrupted by repeated detach no-ops.
	var sim: MovementSimulation = MovementSimulation.new()
	var state: MovementSimulation.MovementState = _make_state(0.0, 0.0, false)
	state.has_chunk = false

	# Simulate 3 frames of no-op detach; reference: same without detach
	var ref_state: MovementSimulation.MovementState = _make_state(0.0, 0.0, false)
	ref_state.has_chunk = false

	var j: int = 0
	while j < 3:
		state = sim.simulate(state, 0.0, false, false, false, 0.0, true, 0.016)
		ref_state = sim.simulate(ref_state, 0.0, false, false, false, 0.0, false, 0.016)
		j += 1

	_assert_approx(state.velocity.y, ref_state.velocity.y,
		"gap04 — 3-frame no-op detach: velocity.y matches reference (no drift)")
	_assert_approx(state.velocity.x, ref_state.velocity.x,
		"gap04 — 3-frame no-op detach: velocity.x matches reference (no drift)")


# ===========================================================================
# GAP-05: delta=0.0 with detach — all 7 MovementState fields verified
# ===========================================================================
# Vulnerability: AC-48.7 (zero delta still fires detach) is tested by the
# primary suite with only has_chunk and velocity.y. A buggy implementation
# might leave other fields in an uninitialized state on a zero-delta frame
# with detach. All 7 fields must be explicitly set.

func test_gap05_delta_zero_detach_all_7_fields() -> void:
	# CHECKPOINT: see [M1-005] Test Breaker — TB-CD-005
	var sim: MovementSimulation = MovementSimulation.new()
	var prior: MovementSimulation.MovementState = _make_state(100.0, -50.0, false)
	prior.has_chunk = true
	prior.coyote_timer = 0.05
	prior.jump_consumed = true
	prior.is_wall_clinging = false
	prior.cling_timer = 0.0

	var result: MovementSimulation.MovementState = sim.simulate(
		prior, 0.0, false, false, false, 0.0, true, 0.0)

	# Field 1: has_chunk — detach fired (delta=0 is irrelevant to detach)
	_assert_false(result.has_chunk,
		"gap05 — delta=0 detach: has_chunk=false (detach is input-driven, not time-driven)")

	# Field 2: velocity.x — with delta=0, no accel/friction applied; x carries forward
	# (air_deceleration = 0 default, no input → no change)
	_assert_approx(result.velocity.x, 100.0,
		"gap05 — delta=0 detach: velocity.x carries forward (no accel with delta=0)")

	# Field 3: velocity.y — with delta=0, gravity adds 0; y carries forward
	_assert_approx(result.velocity.y, -50.0,
		"gap05 — delta=0 detach: velocity.y carries forward (no gravity with delta=0)")

	# Field 4: is_on_floor — pass-through from is_on_floor parameter (false)
	_assert_false(result.is_on_floor,
		"gap05 — delta=0 detach: is_on_floor passes through (false)")

	# Field 5: coyote_timer — airborne with delta=0: timer doesn't advance
	# coyote_timer decrements by delta when airborne; 0.05 - 0.0 = 0.05
	_assert_approx(result.coyote_timer, 0.05,
		"gap05 — delta=0 detach: coyote_timer unchanged (0.05 - 0.0 = 0.05)")

	# Field 6: jump_consumed — on floor=false, no jump: carries forward as true
	_assert_true(result.jump_consumed == true,
		"gap05 — delta=0 detach: jump_consumed carries forward (true)")

	# Field 7 (alternate): cling_timer — no cling active, no change
	_assert_approx(result.cling_timer, 0.0,
		"gap05 — delta=0 detach: cling_timer stays 0.0")


func test_gap05_delta_zero_detach_noop_preserves_all_fields() -> void:
