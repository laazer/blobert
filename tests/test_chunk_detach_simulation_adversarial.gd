# ===========================================================================
# GAP-08: Config mutation between calls has no effect on detach
# ===========================================================================
# Vulnerability: detach logic (SPEC-48) reads only detach_just_pressed and
# prior_state.has_chunk — it reads NO config parameters. A buggy
# implementation might accidentally read max_speed, gravity, or another
# config field in the detach step, causing detach to silently fail or fire
# differently when config is changed between frames.

func test_gap08_config_mutation_does_not_affect_detach() -> void:
	# CHECKPOINT: see [M1-005] Test Breaker — TB-CD-008
	var sim: MovementSimulation = MovementSimulation.new()

	# Frame 1: detach fires normally
	var prior_a: MovementSimulation.MovementState = _make_default_state()
	prior_a.has_chunk = true
	var result_a: MovementSimulation.MovementState = sim.simulate(
		prior_a, 0.0, false, false, false, 0.0, true, 0.016)
	_assert_false(result_a.has_chunk,
		"gap08 — baseline detach fires with default config")

	# Mutate every config parameter on the simulation instance
	sim.max_speed = 9999.0
	sim.gravity = 0.0
	sim.acceleration = 0.0
	sim.friction = 0.0
	sim.air_deceleration = 9999.0
	sim.jump_height = 0.0
	sim.coyote_time = 0.0
	sim.jump_cut_velocity = 0.0
	sim.cling_gravity_scale = 0.0
	sim.max_cling_time = 0.0
	sim.wall_jump_height = 0.0
	sim.wall_jump_horizontal_speed = 0.0

	# Frame 2: detach must still fire despite all config mutations
	var prior_b: MovementSimulation.MovementState = _make_default_state()
	prior_b.has_chunk = true
	var result_b: MovementSimulation.MovementState = sim.simulate(
		prior_b, 0.0, false, false, false, 0.0, true, 0.016)
	_assert_false(result_b.has_chunk,
		"gap08 — detach fires even after all config params mutated to 0/extremes")


func test_gap08_config_mutation_does_not_affect_noop_detach() -> void:
	# Config mutation must not accidentally re-enable detach when has_chunk=false.
	var sim: MovementSimulation = MovementSimulation.new()
	sim.max_speed = 0.0
	sim.gravity = 99999.0
	sim.jump_height = 99999.0

	var prior: MovementSimulation.MovementState = _make_default_state()
	prior.has_chunk = false
	var result: MovementSimulation.MovementState = sim.simulate(
		prior, 0.0, false, false, false, 0.0, true, 0.016)
	_assert_false(result.has_chunk,
		"gap08 — extreme config mutation does not cause no-op detach to fire as detach")


# ===========================================================================
# GAP-09: Instance isolation — detach in one instance does not affect another
# ===========================================================================
# Vulnerability: if MovementSimulation stores shared mutable state at the
# class or static level (class variables instead of instance variables),
# detach called on one instance would affect another. This tests that two
# separate instances are fully isolated.

func test_gap09_two_instances_detach_isolation() -> void:
	# CHECKPOINT: see [M1-005] Test Breaker — TB-CD-009
	var sim_a: MovementSimulation = MovementSimulation.new()
	var sim_b: MovementSimulation = MovementSimulation.new()

	var prior_a: MovementSimulation.MovementState = _make_default_state()
	prior_a.has_chunk = true

	var prior_b: MovementSimulation.MovementState = _make_default_state()
	prior_b.has_chunk = true

	# Detach on sim_a
	var result_a: MovementSimulation.MovementState = sim_a.simulate(
		prior_a, 0.0, false, false, false, 0.0, true, 0.016)

	# No detach on sim_b
	var result_b: MovementSimulation.MovementState = sim_b.simulate(
		prior_b, 0.0, false, false, false, 0.0, false, 0.016)

	_assert_false(result_a.has_chunk,
		"gap09 — instance A: detach fired, has_chunk=false")
	_assert_true(result_b.has_chunk == true,
		"gap09 — instance B: no detach pressed, has_chunk carries forward as true")


func test_gap09_two_instances_interleaved_detach_no_cross_contamination() -> void:
	# Interleave calls: A detaches on frame 1, B detaches on frame 2.
	# Neither instance's output should be affected by the other's detach.
	var sim_a: MovementSimulation = MovementSimulation.new()
	var sim_b: MovementSimulation = MovementSimulation.new()

	# Frame 1: A detaches, B does not
	var state_a: MovementSimulation.MovementState = _make_default_state()
	state_a.has_chunk = true
	var state_b: MovementSimulation.MovementState = _make_default_state()
	state_b.has_chunk = true

	state_a = sim_a.simulate(state_a, 0.0, false, false, false, 0.0, true, 0.016)
	state_b = sim_b.simulate(state_b, 0.0, false, false, false, 0.0, false, 0.016)

	_assert_false(state_a.has_chunk,
		"gap09 interleave — frame 1: A has_chunk=false (detach fired)")
	_assert_true(state_b.has_chunk == true,
		"gap09 interleave — frame 1: B has_chunk=true (no detach)")

	# Frame 2: A carries (no-op detach), B detaches
	state_a = sim_a.simulate(state_a, 0.0, false, false, false, 0.0, false, 0.016)
	state_b = sim_b.simulate(state_b, 0.0, false, false, false, 0.0, true, 0.016)

	_assert_false(state_a.has_chunk,
		"gap09 interleave — frame 2: A has_chunk=false (carry-forward)")
	_assert_false(state_b.has_chunk,
		"gap09 interleave — frame 2: B has_chunk=false (detach fired on frame 2)")


# ===========================================================================
# GAP-10: Repeated no-op stability — 100 consecutive calls
# ===========================================================================
# Vulnerability: the spec guarantees the no-op is stable and deterministic.
# A buggy implementation might accumulate floating-point drift in adjacent
# fields, or set has_chunk=true on some iteration boundary (e.g., a counter
# that wraps). 100 iterations stress-tests this invariant.

func test_gap10_hundred_consecutive_noop_detach_has_chunk_stays_false() -> void:
	# CHECKPOINT: see [M1-005] Test Breaker — TB-CD-010
	var sim: MovementSimulation = MovementSimulation.new()
	var state: MovementSimulation.MovementState = _make_default_state()
	state.has_chunk = false

	var i: int = 0
	var all_false: bool = true
	while i < 100:
		state = sim.simulate(state, 0.0, false, false, false, 0.0, true, 0.016)
		if state.has_chunk:
			all_false = false
		i += 1

	_assert_true(all_false,
		"gap10 — 100 consecutive no-op detach calls: has_chunk stays false every frame")


func test_gap10_hundred_noop_detach_result_is_deterministic() -> void:
	# Run the same 100-frame no-op sequence twice on two separate instances.
	# Both must produce the exact same final velocity.y (gravity accumulation).
	var sim_1: MovementSimulation = MovementSimulation.new()
	var sim_2: MovementSimulation = MovementSimulation.new()

	var state_1: MovementSimulation.MovementState = _make_state(0.0, 0.0, false)
	state_1.has_chunk = false
	var state_2: MovementSimulation.MovementState = _make_state(0.0, 0.0, false)
	state_2.has_chunk = false

	var k: int = 0
	while k < 100:
		state_1 = sim_1.simulate(state_1, 0.0, false, false, false, 0.0, true, 0.016)
		state_2 = sim_2.simulate(state_2, 0.0, false, false, false, 0.0, true, 0.016)
		k += 1

	_assert_approx(state_1.velocity.y, state_2.velocity.y,
		"gap10 — 100-frame no-op: velocity.y is deterministic across two instances")
	_assert_false(state_1.has_chunk,
		"gap10 — 100-frame no-op: instance 1 has_chunk stays false")
	_assert_false(state_2.has_chunk,
		"gap10 — 100-frame no-op: instance 2 has_chunk stays false")


# ===========================================================================
# GAP-11: Normal movement completely unaffected when detach fires
# ===========================================================================
# Vulnerability: the primary suite compares detach vs. no-detach with zero
# velocity and zero axis. This gap targets active movement scenarios:
# non-zero input_axis, active jumping, and active wall clinging — verifying
# that the full physics pipeline is identical whether or not detach fired.

func test_gap11_horizontal_movement_unaffected_when_detach_fires() -> void:
	# CHECKPOINT: see [M1-005] Test Breaker — TB-CD-011
	# Active horizontal run: input_axis=1.0, grounded
	var sim: MovementSimulation = MovementSimulation.new()
	var prior_ref: MovementSimulation.MovementState = _make_state(100.0, 0.0, true)
	prior_ref.has_chunk = true
	var prior_det: MovementSimulation.MovementState = _make_state(100.0, 0.0, true)
	prior_det.has_chunk = true

	var ref_result: MovementSimulation.MovementState = sim.simulate(
		prior_ref, 1.0, false, false, false, 0.0, false, 0.016)
	var det_result: MovementSimulation.MovementState = sim.simulate(
		prior_det, 1.0, false, false, false, 0.0, true, 0.016)

	_assert_approx(det_result.velocity.x, ref_result.velocity.x,
		"gap11 — active horizontal run: velocity.x identical detach vs. no-detach")
	_assert_approx(det_result.velocity.y, ref_result.velocity.y,
		"gap11 — active horizontal run: velocity.y identical detach vs. no-detach")
	_assert_false(det_result.has_chunk,
		"gap11 — active horizontal run: has_chunk=false (detach fired)")


func test_gap11_gravity_accumulation_unaffected_when_detach_fires() -> void:
	# Active airborne state with non-zero velocity; gravity must accumulate
	# identically regardless of detach.
	var sim: MovementSimulation = MovementSimulation.new()
	var prior_ref: MovementSimulation.MovementState = _make_state(-80.0, -300.0, false)
	prior_ref.has_chunk = true
	var prior_det: MovementSimulation.MovementState = _make_state(-80.0, -300.0, false)
	prior_det.has_chunk = true

	var ref_result: MovementSimulation.MovementState = sim.simulate(
		prior_ref, -1.0, false, false, false, 0.0, false, 0.016)
	var det_result: MovementSimulation.MovementState = sim.simulate(
		prior_det, -1.0, false, false, false, 0.0, true, 0.016)

	_assert_approx(det_result.velocity.y, ref_result.velocity.y,
		"gap11 — airborne non-zero vy: gravity unaffected by detach")
	_assert_approx(det_result.velocity.x, ref_result.velocity.x,
		"gap11 — airborne non-zero vx: horizontal velocity unaffected by detach")


func test_gap11_cling_physics_unaffected_when_detach_fires() -> void:
	# Wall clinging with reduced gravity — detach must not alter cling behavior.
	# Pressing left (-1.0) against right wall (normal=1.0) → pressing_toward_wall.
	var sim: MovementSimulation = MovementSimulation.new()
	var prior_ref: MovementSimulation.MovementState = _make_state(0.0, 0.0, false)
	prior_ref.is_wall_clinging = true
	prior_ref.cling_timer = 0.2
	prior_ref.has_chunk = true
	var prior_det: MovementSimulation.MovementState = _make_state(0.0, 0.0, false)
	prior_det.is_wall_clinging = true
	prior_det.cling_timer = 0.2
	prior_det.has_chunk = true

	var ref_result: MovementSimulation.MovementState = sim.simulate(
		prior_ref, -1.0, false, false, true, 1.0, false, 0.016)
	var det_result: MovementSimulation.MovementState = sim.simulate(
		prior_det, -1.0, false, false, true, 1.0, true, 0.016)

	# Cling gravity should be scaled; both results must match
	_assert_approx(det_result.velocity.y, ref_result.velocity.y,
		"gap11 — cling gravity scale: velocity.y identical detach vs. no-detach")
	_assert_eq_bool(det_result.is_wall_clinging, ref_result.is_wall_clinging,
		"gap11 — cling state: is_wall_clinging identical detach vs. no-detach")
	_assert_approx(det_result.cling_timer, ref_result.cling_timer,
		"gap11 — cling timer: cling_timer identical detach vs. no-detach")
	_assert_false(det_result.has_chunk,
		"gap11 — cling+detach: has_chunk=false (detach fired during cling)")


