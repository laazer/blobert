# ===========================================================================
# GAP-15: Two sequential detach presses — first fires, second is no-op
# ===========================================================================
# Vulnerability: SPEC-49 specifies detach_just_pressed is a single-frame
# edge trigger. Two consecutive frames with detach_just_pressed=true should
# produce: frame 1 transitions has_chunk true→false, frame 2 is a no-op.
# A buggy implementation using a held-state flag might fire detach on frame 2
# or otherwise produce an inconsistent second frame.

func test_gap15_first_detach_fires_second_is_noop() -> void:
	# CHECKPOINT: see [M1-005] Test Breaker — TB-CD-015
	var sim: MovementSimulation = MovementSimulation.new()
	var state: MovementSimulation.MovementState = _make_default_state()
	state.has_chunk = true

	# Frame 1: detach_just_pressed=true — detach fires
	state = sim.simulate(state, 0.0, false, false, false, 0.0, true, 0.016)
	_assert_false(state.has_chunk,
		"gap15 — frame 1: detach fires, has_chunk=false (first press)")

	# Frame 2: detach_just_pressed=true again — but has_chunk is already false
	# This must be a no-op (carry-forward false, no state corruption)
	state = sim.simulate(state, 0.0, false, false, false, 0.0, true, 0.016)
	_assert_false(state.has_chunk,
		"gap15 — frame 2: no-op (has_chunk already false), has_chunk stays false")


func test_gap15_third_press_still_noop_and_stable() -> void:
	# Three consecutive detach_just_pressed=true frames.
	# Frame 1 fires; frames 2 and 3 must be stable no-ops.
	var sim: MovementSimulation = MovementSimulation.new()
	var state: MovementSimulation.MovementState = _make_default_state()
	state.has_chunk = true

	state = sim.simulate(state, 0.0, false, false, false, 0.0, true, 0.016)
	_assert_false(state.has_chunk,
		"gap15 — frame 1 of 3: detach fires")

	state = sim.simulate(state, 0.0, false, false, false, 0.0, true, 0.016)
	_assert_false(state.has_chunk,
		"gap15 — frame 2 of 3: no-op, has_chunk stays false")

	state = sim.simulate(state, 0.0, false, false, false, 0.0, true, 0.016)
	_assert_false(state.has_chunk,
		"gap15 — frame 3 of 3: no-op, has_chunk stays false")


