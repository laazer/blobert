func test_gap02_detach_and_wall_jump_same_frame_has_chunk_false() -> void:
	# CHECKPOINT: see [M1-005] Test Breaker — TB-CD-002
	var sim: MovementSimulation = MovementSimulation.new()
	var prior: MovementSimulation.MovementState = _make_state(0.0, 0.0, false)
	prior.has_chunk = true
	prior.is_wall_clinging = true
	prior.cling_timer = 0.1
	prior.jump_consumed = false

	# Wall jump (jump_just_pressed=true while clinging to right wall normal=-1)
	# AND detach (detach_just_pressed=true)
	var result: MovementSimulation.MovementState = sim.simulate(
		prior, -1.0, true, true, true, -1.0, true, 0.016)

	# Detach must fire: has_chunk=false
	_assert_false(result.has_chunk,
		"gap02 — detach fires on wall jump frame: has_chunk=false")

	# Wall jump impulse must fire: velocity.y must be strongly negative
	# wall_jump_impulse = -sqrt(2 * gravity * wall_jump_height)
	# Default wall_jump_height = 100.0
	var expected_wj_vy: float = -sqrt(2.0 * 980.0 * 100.0) + 980.0 * 0.016
	_assert_approx(result.velocity.y, expected_wj_vy,
		"gap02 — wall jump impulse fires on same frame as detach (velocity.y)")


func test_gap02_detach_and_wall_jump_same_frame_jump_consumed_true() -> void:
