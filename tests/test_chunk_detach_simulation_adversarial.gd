# ===========================================================================
# GAP-13: Detach with jump_consumed=true (jump suppressed, detach still fires)
# ===========================================================================
# Vulnerability: jump_consumed=true suppresses jump on this frame. If the
# implementation groups jump+detach eligibility checks, a consumed jump might
# accidentally suppress detach as well.

func test_gap13_detach_fires_when_jump_consumed_true() -> void:
	# CHECKPOINT: see [M1-005] Test Breaker — TB-CD-013
	var sim: MovementSimulation = MovementSimulation.new()
	# Airborne, jump already consumed, detach_just_pressed=true
	var prior: MovementSimulation.MovementState = _make_state(0.0, -200.0, false)
	prior.has_chunk = true
	prior.jump_consumed = true  # prevents jump

	var result: MovementSimulation.MovementState = sim.simulate(
		prior, 0.0, true, true, false, 0.0, true, 0.016)

	# Jump must NOT fire (jump_consumed=true)
	# Jump being consumed means the velocity impulse is not applied.
	# We only verify that jump_consumed stays true (not reset) and detach fires.
	_assert_true(result.jump_consumed == true,
		"gap13 — jump_consumed stays true (jump suppressed): no reset from detach")
	_assert_false(result.has_chunk,
		"gap13 — detach fires independently even when jump_consumed=true (jump suppressed)")


