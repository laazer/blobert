# test_chunk_recall_simulation_adversarial.gd
#
# Adversarial extension of the chunk recall test suite.
# Generated by Test Breaker Agent — 2026-03-02.
#
# This file targets gaps, blind spots, and boundary conditions NOT covered by
# the primary controller-level recall suite in test_chunk_recall_simulation.gd.
# Each test documents the specific vulnerability it probes, focusing on:
#   - rapid repeated detach/recall presses across multiple frames,
#   - recall behavior under extreme delta values (very small / very large),
#   - null/no-op scenarios when the chunk is missing or destroyed mid-recall,
#   - interaction between recall and HP reduction/restoration across frames,
#   - determinism of HP and has_chunk given identical input sequences.
#
# Ticket: FEAT-20260302-chunk-recall-core
#
# Scope:
#   - These tests operate at the PlayerController + test_movement.tscn level,
#     mirroring the primary recall suite. They treat MovementSimulation +
#     HP reduction (M1-006) as underlying implementation details and only
#     assert behaviors that are consistent with:
#       * the assumed recall HP formula documented in
#         test_chunk_recall_simulation.gd (HP-neutral detach+recall cycle),
#       * the HP reduction semantics defined in
#         test_hp_reduction_simulation.gd (single-cost reduction per detach),
#       * the detach semantics defined in
#         test_chunk_detach_simulation.gd (no implicit re-attach in simulate()).
#   - Where behavior is not yet formally specified (e.g., recall during
#     "dead" states, multi-chunk futures), tests either skip gracefully or
#     document the gap in comments rather than enforcing a specific outcome.
#
# This file is a plain Object subclass. It does not extend Node or SceneTree.
# The entry point is run_all(), which is called by tests/run_tests.gd.
#
# It may also be invoked via:
#   godot --headless --path /Users/jacobbrandt/workspace/blobert -s tests/run_tests.gd

class_name ChunkRecallSimulationAdversarialTests
extends Object

const EPSILON: float = 1e-4

var _pass_count: int = 0
var _fail_count: int = 0


# ---------------------------------------------------------------------------
# Helpers (duplicated from primary recall suite to keep this file self-contained)
# ---------------------------------------------------------------------------

func _approx_eq(a: float, b: float) -> bool:
	return abs(a - b) < EPSILON


func _pass(test_name: String) -> void:
	_pass_count += 1
	print("  PASS: " + test_name)


func _fail(test_name: String, message: String) -> void:
	_fail_count += 1
	print("  FAIL: " + test_name + " — " + message)


func _assert_true(condition: bool, test_name: String) -> void:
	if condition:
		_pass(test_name)
	else:
		_fail(test_name, "expected true, got false")


func _assert_false(condition: bool, test_name: String) -> void:
	if not condition:
		_pass(test_name)
	else:
		_fail(test_name, "expected false, got true")


func _assert_approx(a: float, b: float, test_name: String) -> void:
	if _approx_eq(a, b):
		_pass(test_name)
	else:
		_fail(test_name, "got " + str(a) + " expected " + str(b) + " (delta " + str(abs(a - b)) + ")")


func _load_main_scene() -> Node:
	var packed: PackedScene = load("res://scenes/test_movement.tscn") as PackedScene
	if packed == null:
		_fail("scene_load_main_adversarial", "could not load res://scenes/test_movement.tscn")
		return null
	var inst: Node = packed.instantiate()
	if inst == null:
		_fail("scene_instantiate_main_adversarial", "instantiate() returned null for test_movement.tscn")
		return null
	return inst


func _get_player(root: Node) -> PlayerController:
	if root == null:
		return null
	var player: PlayerController = root.get_node_or_null("Player") as PlayerController
	return player


func _cleanup_input() -> void:
	# Best-effort: release actions that these tests might have pressed.
	Input.action_release("move_left")
	Input.action_release("move_right")
	Input.action_release("jump")
	Input.action_release("detach")


func _step_player(controller: PlayerController, frames: int, delta: float) -> void:
	var i: int = 0
	while i < frames:
		controller._physics_process(delta)
		i += 1


func _detach_once(controller: PlayerController, delta: float) -> void:
	_cleanup_input()
	Input.action_press("detach")
	controller._physics_process(delta)
	Input.action_release("detach")


func _recall_once(controller: PlayerController, delta: float) -> void:
	_cleanup_input()
	Input.action_press("detach")
	controller._physics_process(delta)
	Input.action_release("detach")


func _supports_hp_fields(player: PlayerController) -> bool:
	# Mirrors test_chunk_recall_simulation.gd: HP-focused tests only run once
	# MovementState.current_hp and MovementSimulation HP config fields exist.
	var state := player._current_state
	if state == null:
		return false
	if not ("current_hp" in state):
		return false
	if not ("max_hp" in player._simulation) or not ("hp_cost_per_detach" in player._simulation):
		return false
	return true


func _configure_hp_for_recall(player: PlayerController, max_hp: float, cost: float, starting_hp: float) -> void:
	player._simulation.max_hp = max_hp
	player._simulation.hp_cost_per_detach = cost
	player._current_state.current_hp = starting_hp


# Helper used for determinism tests: runs a fixed detach+recall spam sequence
# and returns (has_chunk_final, current_hp_final) as a Dictionary.
func _run_standard_detach_recall_sequence(delta_detach: float, delta_recall: float) -> Dictionary:
	var root: Node = _load_main_scene()
	if root == null:
		return {}

	var player: PlayerController = _get_player(root)
	if player == null:
		_fail("determinism_player_exists", "Player node is not a PlayerController in test_movement.tscn")
		root.free()
		return {}

	player._ready()
	_cleanup_input()

	if _supports_hp_fields(player):
		_configure_hp_for_recall(player, 100.0, 25.0, 100.0)

	# Frame 1: detach
	_detach_once(player, delta_detach)

	# Frames 2–6: spam recall on alternating frames to stress input routing.
	var k: int = 0
	while k < 5:
		if k % 2 == 0:
			_recall_once(player, delta_recall)
		else:
			_cleanup_input()
			player._physics_process(delta_recall)
		k += 1

	# Allow homing/reabsorption to finish.
	_step_player(player, 30, delta_recall)

	var result: Dictionary = {}
	result["has_chunk"] = player._current_state != null and player._current_state.has_chunk
	if _supports_hp_fields(player):
		result["current_hp"] = player._current_state.current_hp
	else:
		result["current_hp"] = null

	root.free()
	return result


# ===========================================================================
# TB-CR-001 — Rapid repeated detach/recall presses and HP neutrality
#
# VULNERABILITY:
#   The primary recall tests cover a single detach+recall cycle, but do not
#   stress rapid repeated detach/recall presses across multiple frames. A
#   buggy controller could:
#     - apply the detach HP cost more than once for a single physical detach,
#     - apply the recall HP restoration more than once,
#     - mis-route quick subsequent presses as additional detaches or recalls.
#   This test encodes the intended invariant that:
#     * exactly one HP reduction occurs per detach,
#     * exactly one HP restoration occurs per successful reabsorption, and
#     * a clean detach→recall cycle starting at max_hp is HP-neutral even
#       under aggressive input spam.
# ===========================================================================

func test_tb_cr_001_rapid_detach_recall_spam_is_hp_neutral_and_single_cost() -> void:
	# VULNERABILITY: Rapid recall spam must not multiply HP restoration — only one
	# reabsorption event should occur per detach/recall cycle.
	#
	# SPEC-70 Pattern B: inject _recall_in_progress=true after establishing post-detach
	# state. In headless mode, Input.is_action_just_pressed("detach") stays true
	# permanently after Input.action_press() (engine input flush never runs between
	# direct _physics_process() calls). This means the `not _recall_in_progress` guard
	# is the sole mechanism preventing re-entry — exactly what this test validates.
	# The 16 frames accumulate 0.256s > 0.25s threshold so recall completes. We assert
	# on frame 16 BEFORE frame 17 can trigger a new detach (when has_chunk=true again
	# and detach_just_pressed is still true).
	var root: Node = _load_main_scene()
	if root == null:
		return

	var player: PlayerController = _get_player(root)
	if player == null:
		_fail("tb_cr_001_player_exists", "Player node is not a PlayerController in test_movement.tscn")
		root.free()
		return

	player._ready()
	_cleanup_input()

	if not _supports_hp_fields(player):
		_pass("tb_cr_001_hp_fields_not_present_yet — rapid detach/recall HP tests skipped until HP fields exist")
		root.free()
		return

	_configure_hp_for_recall(player, 100.0, 25.0, 100.0)

	var hp_start: float = player._current_state.current_hp

	# Frame 1: detach — HP decreases by cost.
	_detach_once(player, 0.016)
	if player._chunk_node == null:
		_fail("tb_cr_001_detach_spawned_chunk", "Detach did not spawn a chunk; cannot test recall spam")
		root.free()
		return

	var hp_after_detach: float = player._current_state.current_hp
	_assert_approx(hp_after_detach, 75.0, "tb_cr_001_after_detach_single_cost_applied")

	# Pattern B: inject recall state directly to ensure recall is in progress.
	player._recall_in_progress = true
	player._recall_timer = 0.0

	# Step 16 frames, tracking min/max HP throughout:
	#   - Frames 1–15: timer accumulates 0.016..0.240s (< 0.25 threshold).
	#                  detach_just_pressed=true but has_chunk=false → no new detach.
	#                  _recall_in_progress=true guards against recall re-entry.
	#                  HP stays at 75 throughout (no change).
	#   - Frame 16:    timer reaches 0.256s >= 0.25s → recall COMPLETES.
	#                  HP restored to 100. has_chunk=true. chunk_node=null.
	# We assert IMMEDIATELY after frame 16, before frame 17 can trigger a new detach.
	var min_hp_observed: float = hp_after_detach
	var max_hp_observed: float = hp_after_detach

	var i: int = 0
	while i < 16:
		player._physics_process(0.016)
		var hp_now: float = player._current_state.current_hp
		if hp_now < min_hp_observed:
			min_hp_observed = hp_now
		if hp_now > max_hp_observed:
			max_hp_observed = hp_now
		i += 1

	var hp_final: float = player._current_state.current_hp
	_assert_approx(min_hp_observed, 75.0,
		"tb_cr_001_min_hp_during_spam_not_below_single_cost")
	_assert_true(max_hp_observed <= hp_start + EPSILON,
		"tb_cr_001_hp_during_spam_never_exceeds_starting_hp_before_final_recall")
	_assert_approx(hp_final, hp_start,
		"tb_cr_001_final_hp_returns_to_start_after_single_cycle_despite_spam")

	_assert_true(player._current_state.has_chunk,
		"tb_cr_001_final_has_chunk_true_after_recall_cycle")
	_assert_true(player._chunk_node == null or not is_instance_valid(player._chunk_node),
		"tb_cr_001_final_chunk_node_cleared_after_recall_cycle")

	root.free()


# ===========================================================================
# TB-CR-002 — Recall during airborne motion remains non-blocking and completes
#
# VULNERABILITY:
#   The primary R4 test verifies non-blocking horizontal movement on the recall
#   frame but only in a grounded scenario. This test drives a detach on ground,
#   then transitions to airborne via jump and triggers recall mid-air while
#   holding horizontal input. A buggy controller could:
#     - refuse to process recall while airborne,
#     - zero-out or freeze horizontal velocity during airborne recall,
#     - fail to complete reabsorption when recall begins in the air.
# ===========================================================================

func test_tb_cr_002_recall_while_airborne_is_non_blocking_and_completes() -> void:
	# VULNERABILITY: Recall initiated while airborne must not zero horizontal velocity
	# and must still complete reabsorption. Tests SPEC-66 (non-blocking movement during
	# recall) in an airborne context not covered by the primary R4 test.
	#
	# SPEC-70 Pattern B: inject _recall_in_progress=true and _recall_timer=0.0 directly
	# after establishing the airborne state with a detached chunk. The non-blocking
	# assertion verifies that running recall frames alongside active movement input
	# does not suppress horizontal velocity.
	var root: Node = _load_main_scene()
	if root == null:
		return

	var player: PlayerController = _get_player(root)
	if player == null:
		_fail("tb_cr_002_player_exists", "Player node is not a PlayerController in test_movement.tscn")
		root.free()
		return

	player._ready()
	_cleanup_input()

	# Baseline: ensure initial chunk state.
	_assert_true(player._current_state != null, "tb_cr_002_initial_state_allocated")
	_assert_true(player._current_state.has_chunk, "tb_cr_002_initial_has_chunk_true")

	# Step a frame to settle grounding.
	player._physics_process(0.016)

	# Detach on ground.
	_detach_once(player, 0.016)
	if player._chunk_node == null:
		_fail("tb_cr_002_detach_spawned_chunk", "Detach did not spawn a chunk; cannot test airborne recall")
		root.free()
		return

	# Jump to become airborne.
	_cleanup_input()
	Input.action_press("jump")
	player._physics_process(0.016)
	Input.action_release("jump")

	# Advance a few frames to ensure airborne state.
	_step_player(player, 5, 0.016)

	# Prime horizontal motion to the right while airborne.
	Input.action_press("move_right")
	player._physics_process(0.016)
	var vx_before_recall: float = player.velocity.x
	_assert_true(vx_before_recall > 0.0, "tb_cr_002_airborne_horizontal_velocity_positive_before_recall")

	# Pattern B: inject recall state directly to ensure recall is in progress.
	# This tests the timer path while the player is airborne and moving right.
	player._recall_in_progress = true
	player._recall_timer = 0.0

	# Step exactly 16 frames while holding move_right to verify non-blocking behavior.
	# Recall completes on frame 16 (timer=0.256s >= 0.25s threshold).
	# We assert IMMEDIATELY after frame 16, before frame 17 triggers a new detach
	# due to the persistent headless detach input state.
	var f: int = 0
	while f < 16:
		player._physics_process(0.016)
		f += 1

	var vx_after_recall: float = player.velocity.x
	_assert_true(vx_after_recall > 0.0,
		"tb_cr_002_airborne_recall_does_not_zero_horizontal_velocity")
	_assert_true(vx_after_recall >= vx_before_recall - EPSILON,
		"tb_cr_002_airborne_recall_does_not_reverse_horizontal_velocity")

	_assert_true(player._current_state.has_chunk,
		"tb_cr_002_after_airborne_recall_has_chunk_true")
	_assert_true(player._chunk_node == null or not is_instance_valid(player._chunk_node),
		"tb_cr_002_after_airborne_recall_chunk_node_cleared")

	_cleanup_input()
	root.free()


# ===========================================================================
# TB-CR-003 — Recall with chunk destroyed mid-flight does not restore HP
#
# VULNERABILITY:
#   R3 in the primary suite covers detach followed by manual deletion of the
#   chunk BEFORE recall is attempted. It does not cover a scenario where recall
#   is initiated correctly but the chunk is destroyed mid-flight (e.g. it
#   passes through a kill volume). A naïve implementation might:
#     - restore HP even though the chunk never arrived,
#     - set has_chunk=true despite there being no live chunk,
#     - crash by dereferencing a freed chunk node.
#   This test encodes the conservative invariant that HP restoration and
#   reattachment only occur when a live chunk successfully completes recall.
# ===========================================================================

func test_tb_cr_003_recall_with_chunk_destroyed_mid_flight_does_not_restore_hp() -> void:
	var root: Node = _load_main_scene()
	if root == null:
		return

	var player: PlayerController = _get_player(root)
	if player == null:
		_fail("tb_cr_003_player_exists", "Player node is not a PlayerController in test_movement.tscn")
		root.free()
		return

	player._ready()
	_cleanup_input()

	if not _supports_hp_fields(player):
		_pass("tb_cr_003_hp_fields_not_present_yet — mid-flight destruction HP tests skipped until HP fields exist")
		root.free()
		return

	_configure_hp_for_recall(player, 100.0, 25.0, 100.0)

	# Detach once to spawn a chunk and apply the HP cost.
	_detach_once(player, 0.016)
	if player._chunk_node == null:
		_fail("tb_cr_003_detach_spawned_chunk", "Detach did not spawn a chunk; cannot test mid-flight destruction")
		root.free()
		return

	var hp_after_detach: float = player._current_state.current_hp
	_assert_approx(hp_after_detach, 75.0, "tb_cr_003_after_detach_hp_reduced_by_cost")

	# Trigger recall, then destroy the chunk while recall is "in flight".
	_recall_once(player, 0.016)

	if is_instance_valid(player._chunk_node):
		player._chunk_node.queue_free()
	player._chunk_node = null

	# Advance simulation to allow any recall bookkeeping to run.
	_step_player(player, 60, 0.016)

	# Invariant: with no live chunk to reabsorb, recall should not:
	#   - flip has_chunk back to true,
	#   - restore HP from the detached value.
	_assert_false(player._current_state.has_chunk,
		"tb_cr_003_mid_flight_destruction_does_not_mark_has_chunk_true")
	_assert_true(player._chunk_node == null or not is_instance_valid(player._chunk_node),
		"tb_cr_003_mid_flight_destruction_keeps_chunk_node_null_or_freed")

	var hp_final: float = player._current_state.current_hp
	_assert_approx(hp_final, hp_after_detach,
		"tb_cr_003_mid_flight_destruction_does_not_restore_hp_without_chunk")

	root.free()


# ===========================================================================
# TB-CR-004 — Large-delta recall completes without HP or state corruption
#
# VULNERABILITY:
#   The primary recall tests use a fixed delta ~0.016 (60 FPS). No test covers
#   very large delta values which can occur after frame hitches or when running
#   the simulation with low FPS. A buggy implementation might:
#     - overshoot homing logic and fail to reabsorb the chunk,
#     - process multiple detach/recall "steps" in a single frame,
#     - incorrectly apply HP restoration more than once.
# ===========================================================================

func test_tb_cr_004_large_delta_recall_completes_and_preserves_hp_neutrality() -> void:
	var root: Node = _load_main_scene()
	if root == null:
		return

	var player: PlayerController = _get_player(root)
	if player == null:
		_fail("tb_cr_004_player_exists", "Player node is not a PlayerController in test_movement.tscn")
		root.free()
		return

	player._ready()
	_cleanup_input()

	if not _supports_hp_fields(player):
		_pass("tb_cr_004_hp_fields_not_present_yet — large-delta HP tests skipped until HP fields exist")
		root.free()
		return

	_configure_hp_for_recall(player, 100.0, 25.0, 100.0)

	var hp_start: float = player._current_state.current_hp

	# Detach with a normal frame delta.
	_detach_once(player, 0.016)
	var hp_after_detach: float = player._current_state.current_hp
	_assert_approx(hp_after_detach, 75.0, "tb_cr_004_after_detach_hp_reduced_by_cost")

	# Trigger recall and then simulate a few very large-delta frames.
	_recall_once(player, 0.25)
	_step_player(player, 4, 0.25)

	# Invariants: recall still completes and the overall cycle remains HP-neutral.
	_assert_true(player._current_state.has_chunk,
		"tb_cr_004_large_delta_recall_still_results_in_has_chunk_true")
	_assert_true(player._chunk_node == null or not is_instance_valid(player._chunk_node),
		"tb_cr_004_large_delta_recall_clears_chunk_node")

	var hp_final: float = player._current_state.current_hp
	_assert_approx(hp_final, hp_start,
		"tb_cr_004_large_delta_detach_recall_cycle_is_hp_neutral")

	root.free()


# ===========================================================================
# TB-CR-005 — Null/no-op recall when no chunk has ever been detached
#
# VULNERABILITY:
#   R3 focuses on the case where a chunk was detached and then removed. This
#   test targets the scenario where the player spams the detach/recall input
#   from the very start of the scene without ever successfully detaching a
#   chunk. A buggy implementation could:
#     - accidentally spawn or recall a non-existent chunk,
#     - alter HP despite there being no detach event,
#     - crash due to uninitialized chunk handles.
# ===========================================================================

func test_tb_cr_005_recall_spam_without_any_prior_detach_is_noop() -> void:
	# VULNERABILITY: Pressing "detach" when has_chunk=false and _chunk_node=null
	# (chunk was never detached, or was already lost without ever triggering recall)
	# must be a pure no-op for recall. No chunk should spawn, no HP should change,
	# and has_chunk must stay false. This exercises SPEC-62's third routing branch:
	# the no-op case where neither detach (has_chunk=true required) nor recall
	# (live chunk required) conditions are met.
	#
	# NOTE: Starting from has_chunk=true and pressing "detach" triggers a DETACH
	# (not a recall no-op) — that is correct behavior. This test explicitly puts
	# the player into the "chunk was lost with no live node" state (has_chunk=false,
	# _chunk_node=null) and then verifies that spam does not spawn/restore anything.
	var root: Node = _load_main_scene()
	if root == null:
		return

	var player: PlayerController = _get_player(root)
	if player == null:
		_fail("tb_cr_005_player_exists", "Player node is not a PlayerController in test_movement.tscn")
		root.free()
		return

	player._ready()
	_cleanup_input()

	var hp_supported: bool = _supports_hp_fields(player)
	if hp_supported:
		_configure_hp_for_recall(player, 100.0, 25.0, 100.0)

	# Force the "chunk lost, nothing to recall" state:
	#   - has_chunk=false: simulates that a chunk was detached previously
	#   - _chunk_node=null: simulates that chunk was destroyed (no live node)
	# This is SPEC-62's no-op routing branch: detach_just_pressed=true but
	# has_chunk=false AND _chunk_node=null — neither detach nor recall fires.
	player._current_state.has_chunk = false
	player._chunk_node = null
	var hp_before_spam: float = 0.0
	if hp_supported:
		hp_before_spam = player._current_state.current_hp

	# Sanity checks on the injected state.
	_assert_false(player._current_state.has_chunk, "tb_cr_005_precondition_has_chunk_false")
	_assert_true(player._chunk_node == null, "tb_cr_005_precondition_no_chunk_node")

	# Spam detach/recall input for many frames in this "no chunk" state.
	# Each press: has_chunk=false and _chunk_node=null → no detach, no recall, no-op.
	var frame: int = 0
	while frame < 30:
		_recall_once(player, 0.016)
		frame += 1

	if hp_supported:
		var hp_final: float = player._current_state.current_hp
		_assert_approx(hp_final, hp_before_spam,
			"tb_cr_005_recall_spam_without_detach_does_not_change_hp")

	_assert_false(player._current_state.has_chunk,
		"tb_cr_005_recall_spam_without_detach_does_not_flip_has_chunk_false")
	_assert_true(player._chunk_node == null or not is_instance_valid(player._chunk_node),
		"tb_cr_005_recall_spam_without_detach_does_not_spawn_chunk")

	root.free()


# ===========================================================================
# TB-CR-006 — Determinism: identical detach/recall spam sequences produce
#             identical HP and has_chunk outcomes
#
# VULNERABILITY:
#   The primary suites assert determinism for MovementSimulation and HP
#   reduction in isolation but do not verify determinism across the combined
#   PlayerController + recall homing + HP restoration pipeline. A recall
#   implementation that uses time-dependent randomness or reads mutable global
#   state could produce divergent results for the same input sequence.
# ===========================================================================

func test_tb_cr_006_determinism_for_standard_detach_recall_sequence() -> void:
	var result_a: Dictionary = _run_standard_detach_recall_sequence(0.016, 0.016)
	var result_b: Dictionary = _run_standard_detach_recall_sequence(0.016, 0.016)

	if result_a.is_empty() or result_b.is_empty():
		# Scene load failure or similar already reported by helpers.
		return

	_assert_true(result_a["has_chunk"] == result_b["has_chunk"],
		"tb_cr_006_determinism_has_chunk_matches_between_runs")

	# Only assert HP determinism when HP fields are present; when they are not,
	# both dictionaries will carry null and this assertion will still pass.
	_assert_true(result_a["current_hp"] == result_b["current_hp"],
		"tb_cr_006_determinism_current_hp_matches_between_runs")


# ===========================================================================
# Public entry point
