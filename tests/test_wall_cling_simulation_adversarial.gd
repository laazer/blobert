# TB-WC-013a: cling_timer exactly equal to max_cling_time (not just 1.5 == 1.5)
# Test with a custom max_cling_time=0.5, prior.cling_timer=0.5 → 0.5 < 0.5 is false
# Ensures the strict < boundary holds for non-default values of max_cling_time.
func test_cling_timer_equals_custom_max_cling_time_blocked() -> void:
	# Vulnerability: if the implementation uses <= instead of < in the timer check,
	# this test fails only for non-default values if the default 1.5 was accidentally
	# hardcoded as a pass condition.
	var sim: MovementSimulation = MovementSimulation.new()
	sim.max_cling_time = 0.5
	var prior: MovementSimulation.MovementState = _make_state_with(0.0, 0.0, false)
	prior.jump_consumed = false
	prior.cling_timer = 0.5  # exactly equal to custom max
	var result: MovementSimulation.MovementState = sim.simulate(prior, -1.0, false, false, true, 1.0, false, 0.016)
	_assert_false(result.is_wall_clinging,
		"TB-WC-013a — custom max_cling_time=0.5, timer=0.5: 0.5<0.5 is false → blocked")


# TB-WC-013b: wall_normal_x = 0.0001 (almost zero, but positive)
# Input_axis=-1.0: product = -1.0 * 0.0001 = -0.0001 < 0.0 → TRUE → pressing toward wall
# An implementation that treats any near-zero normal as zero would block this incorrectly.
func test_near_zero_positive_wall_normal_x_still_clings() -> void:
	# Vulnerability: if the implementation checks |wall_normal_x| > threshold before
	# using it, a very small but positive normal would incorrectly block cling.
	var sim: MovementSimulation = MovementSimulation.new()
	var prior: MovementSimulation.MovementState = _make_state_with(0.0, 0.0, false)
	prior.jump_consumed = false
	var result: MovementSimulation.MovementState = sim.simulate(prior, -1.0, false, false, true, 0.0001, false, 0.016)
	_assert_true(result.is_wall_clinging,
		"TB-WC-013b — wall_normal_x=0.0001, axis=-1.0: product=-0.0001<0 → pressing toward wall → cling")


# TB-WC-013c: wall_normal_x = -0.0001 (almost zero negative)
# input_axis=1.0: product = 1.0 * -0.0001 = -0.0001 < 0.0 → TRUE → pressing toward wall
func test_near_zero_negative_wall_normal_x_still_clings() -> void:
	# Vulnerability: same as TB-WC-013b but for negative near-zero wall normal.
	var sim: MovementSimulation = MovementSimulation.new()
	var prior: MovementSimulation.MovementState = _make_state_with(0.0, 0.0, false)
	prior.jump_consumed = false
	var result: MovementSimulation.MovementState = sim.simulate(prior, 1.0, false, false, true, -0.0001, false, 0.016)
	_assert_true(result.is_wall_clinging,
		"TB-WC-013c — wall_normal_x=-0.0001, axis=1.0: product=-0.0001<0 → pressing toward wall → cling")


# TB-WC-013d: very large delta — cling_timer increments by the clamped large delta
# delta=10.0 (simulating a 10-second hitch): cling_timer = prior + 10.0
# With prior.cling_timer=0.0 and max_cling_time=1.5: timer would become 10.0 > 1.5
# But eligibility is checked on prior.cling_timer (0.0 < 1.5 → eligible this frame).
# result.cling_timer should be 0.0 + 10.0 = 10.0 (even though it now exceeds max).
# On the NEXT frame with prior.cling_timer=10.0 → not eligible.
func test_very_large_delta_cling_timer_increments_correctly() -> void:
	# Vulnerability: an implementation that clamps the accumulated timer to max_cling_time
	# would produce 1.5 instead of 10.0. But the timer is raw accumulation; eligibility
	# check is a separate gate. The timer should accumulate honestly.
	var sim: MovementSimulation = MovementSimulation.new()
	var prior: MovementSimulation.MovementState = _make_state_with(0.0, 0.0, false)
	prior.jump_consumed = false
	prior.cling_timer = 0.0
	var result: MovementSimulation.MovementState = sim.simulate(prior, -1.0, false, false, true, 1.0, false, 10.0)
	# This frame: prior.cling_timer=0.0 < 1.5 → eligible (cling fires this frame)
	_assert_true(result.is_wall_clinging,
		"TB-WC-013d — large delta=10.0: eligible this frame (prior timer=0.0 < 1.5)")
	# Timer accumulates by full large delta
	_assert_approx(result.cling_timer, 10.0,
		"TB-WC-013d — large delta=10.0: cling_timer = 0.0 + 10.0 = 10.0 (not clamped to 1.5)")


# TB-WC-013e: very large delta, second frame — prior.cling_timer=10.0 → expired immediately
func test_very_large_delta_second_frame_immediately_expired() -> void:
	# Vulnerability: if the timer was incorrectly clamped to 1.5 in TB-WC-013d,
	# this test would see 1.5 < 1.5 = false (still would block, passing coincidentally).
	# The pair of tests is meaningful: 013d checks accumulation, 013e checks the next frame.
	var sim: MovementSimulation = MovementSimulation.new()
	var prior: MovementSimulation.MovementState = _make_state_with(0.0, 0.0, false)
	prior.jump_consumed = false
	prior.cling_timer = 10.0  # accumulated from a large-delta frame
	var result: MovementSimulation.MovementState = sim.simulate(prior, -1.0, false, false, true, 1.0, false, 0.016)
	_assert_false(result.is_wall_clinging,
		"TB-WC-013e — prior.cling_timer=10.0 > max=1.5: immediately expired on next frame")


