class_name EnemyStateMachineAdversarialTests
extends Object


const ALLOWED_STATES: Array[String] = [
	"idle",
	"active",
	"weakened",
	"infected",
	"dead",
]


var _pass_count: int = 0
var _fail_count: int = 0


# ---------------------------------------------------------------------------
# Helpers (duplicated from base suite — this file must be self-contained)
# ---------------------------------------------------------------------------

func _pass(test_name: String) -> void:
	_pass_count += 1
	print("  PASS: " + test_name)


func _fail(test_name: String, message: String) -> void:
	_fail_count += 1
	print("  FAIL: " + test_name + " — " + message)


func _assert_true(condition: bool, test_name: String) -> void:
	if condition:
		_pass(test_name)
	else:
		_fail(test_name, "expected true, got false")


func _assert_state(expected: String, actual: String, test_name: String) -> void:
	if actual == expected:
		_pass(test_name)
	else:
		_fail(
			test_name,
			"expected state '" + expected + "', got '" + actual + "'"
		)


func _assert_state_allowed(actual: String, test_name: String) -> void:
	if ALLOWED_STATES.has(actual):
		_pass(test_name)
	else:
		_fail(
			test_name,
			"state '" + actual + "' is not in ALLOWED_STATES " + str(ALLOWED_STATES)
		)


func _make_machine() -> EnemyStateMachine:
	var machine: EnemyStateMachine = EnemyStateMachine.new()
	return machine


func _state_of(machine: EnemyStateMachine) -> String:
	return machine.get_state()


# ===========================================================================
# [M2-ESM] TB-001 — Weaken event while infected must be a no-op
#
# VULNERABILITY: Existing tests cover infection while not weakened and repeated
# weaken while already weakened as no-ops, but they do not assert behavior for
# weaken events applied AFTER an enemy is already infected. A buggy
# implementation might allow "infected → weakened" or some other transition,
# silently corrupting the infection loop by making infected enemies re-weaken.
#
# CHECKPOINT [enemy_state_machine] TB-001 — weaken from infected
# Would have asked: Once an enemy is in the "infected" state, should
# apply_weaken_event() ever change its lifecycle state, or must infection be a
# terminal pre-death state where further weaken events are treated as no-ops?
# Assumption made: For this ticket, "infected" is terminal with respect to
# weakening; apply_weaken_event() from "infected" is a deterministic no-op and
# must leave the state at "infected".
# Confidence: Medium
# ===========================================================================

func test_tb001_weaken_from_infected_is_noop() -> void:
	# CHECKPOINT
	var machine: EnemyStateMachine = _make_machine()

	# Drive to infected.
	machine.apply_weaken_event()
	machine.apply_infection_event()
	var infected_before: String = _state_of(machine)
	_assert_state(
		"infected",
		infected_before,
		"tb001_precondition_infected — weaken+infect reaches 'infected'"
	)

	# Apply weaken again; state must stay infected.
	machine.apply_weaken_event()
	var infected_after: String = _state_of(machine)
	_assert_state(
		infected_before,
		infected_after,
		"tb001_weaken_from_infected_noop — weaken event from 'infected' leaves state unchanged"
	)


# ===========================================================================
# [M2-ESM] TB-002 — reset() must revive from all non-initial states
#
# VULNERABILITY: Primary tests assert reset() from a non-idle, non-dead state
# (weakened) returns to "idle", but do not exercise reset() from "infected" or
# "dead". An implementation that refuses to reset from dead (treating it as
# irrecoverable) or that half-resets (e.g., "dead" → "weakened") would break
# deterministic control over enemy lifecycles in tests and tooling.
#
# CHECKPOINT [enemy_state_machine] TB-002 — reset semantics from dead/infected
# Would have asked: Should reset() be allowed to revive enemies from "dead" and
# "infected" back to the initial "idle" state for testing/tools, or must dead
# be an unrecoverable terminal state that cannot be reset?
# Assumption made: For this ticket, reset() is a pure test/tooling affordance
# that returns the state machine to its initial "idle" state from ANY prior
# state, including "infected" and "dead", without side effects.
# Confidence: Medium
# ===========================================================================

func test_tb002_reset_from_infected_restores_idle() -> void:
	# CHECKPOINT
	var machine: EnemyStateMachine = _make_machine()
	machine.apply_weaken_event()
	machine.apply_infection_event()
	var infected_before: String = _state_of(machine)
	_assert_state(
		"infected",
		infected_before,
		"tb002_precondition_infected — weaken+infect reaches 'infected'"
	)

	machine.reset()
	var after_reset: String = _state_of(machine)
	_assert_state(
		"idle",
		after_reset,
		"tb002_reset_from_infected_idle — reset() from 'infected' returns to 'idle'"
	)


func test_tb002_reset_from_dead_restores_idle() -> void:
	# CHECKPOINT
	var machine: EnemyStateMachine = _make_machine()
	machine.apply_death_event()
	var dead_before: String = _state_of(machine)
	_assert_state(
		"dead",
		dead_before,
		"tb002_precondition_dead — death event reaches 'dead'"
	)

	machine.reset()
	var after_reset: String = _state_of(machine)
	_assert_state(
		"idle",
		after_reset,
		"tb002_reset_from_dead_idle — reset() from 'dead' returns to 'idle'"
	)


# ===========================================================================
# [M2-ESM] TB-003 — State labels must remain valid and non-empty under stress
#
# VULNERABILITY: The primary suite checks allowed states for a small fixed
# sequence only. An implementation that accidentally leaks an intermediate or
# debugging state label under more complex sequences (e.g., "pending_infect")
# would go unnoticed. This test applies a longer mixed sequence, including
# resets and repeated no-ops, and asserts states always remain in the canonical
# allowed set and are never empty strings.
# ===========================================================================

func test_tb003_long_mixed_sequence_remains_within_allowed_states() -> void:
	var machine: EnemyStateMachine = _make_machine()

	var sequence: Array[String] = []
	# Build a deterministic pattern of events, including many no-ops.
	for i in 200:
		match i % 6:
			0:
				sequence.append("weaken")
			1:
				sequence.append("infect")
			2:
				sequence.append("death")
			3:
				sequence.append("reset")
			4:
				sequence.append("infect")
			5:
				sequence.append("weaken")

	for idx in sequence.size():
		var step: String = sequence[idx]
		match step:
			"weaken":
				machine.apply_weaken_event()
			"infect":
				machine.apply_infection_event()
			"death":
				machine.apply_death_event()
			"reset":
				machine.reset()
			_:
				pass

		var state: String = _state_of(machine)
		_assert_true(
			state != "",
			"tb003_non_empty_state_after_step_" + str(idx) + " — state label must never be empty"
		)
		_assert_state_allowed(
			state,
			"tb003_allowed_state_after_step_" + str(idx) + " — state label remains within canonical set under stress sequence"
		)


# ===========================================================================
# [M2-ESM] TB-004 — Events after dead remain no-ops under stress
#
# VULNERABILITY: The primary suite checks a single batch of weaken/infect/death
# calls after reaching "dead". An implementation that accidentally allows
# resurrection after many frames (e.g., via an internal timer) would not be
# caught. This test performs many cycles of events after "dead" and asserts the
# state never leaves "dead".
# ===========================================================================

func test_tb004_repeated_events_after_dead_never_leave_dead() -> void:
	var machine: EnemyStateMachine = _make_machine()
	machine.apply_weaken_event()
	machine.apply_infection_event()
	machine.apply_death_event()

	var dead_initial: String = _state_of(machine)
	_assert_state(
		"dead",
		dead_initial,
		"tb004_precondition_dead — machine is in 'dead' before stress loop"
	)

	for i in 100:
		machine.apply_weaken_event()
		machine.apply_infection_event()
		machine.apply_death_event()
		var state: String = _state_of(machine)
		_assert_state(
			"dead",
			state,
			"tb004_dead_persists_iteration_" + str(i) + " — all events after 'dead' leave state at 'dead'"
		)


# ===========================================================================
# [M2-ESM] TB-005 — reset() idempotency from idle
#
# VULNERABILITY: If reset() mutates internal bookkeeping beyond the visible
# state label (e.g., counters, flags) in a way that accidentally changes
# behavior when called multiple times from "idle", repeated tooling/test
# invocations could diverge. This test asserts that many consecutive reset()
# calls from "idle" never leave "idle".
# ===========================================================================

func test_tb005_multiple_resets_from_idle_are_idempotent() -> void:
	var machine: EnemyStateMachine = _make_machine()

	for i in 50:
		machine.reset()
		var state: String = _state_of(machine)
		_assert_state(
			"idle",
			state,
			"tb005_reset_idempotent_iteration_" + str(i) + " — repeated reset() from 'idle' stays 'idle'"
		)


# ===========================================================================
# [M2-ESM] TB-006 — Many instances do not share state
#
# VULNERABILITY: Spec checkpoints require per-instance determinism and no
# shared mutable state, but the primary suite only checks two instances. A
# mistaken implementation that stores state in a static/global variable could
# still pass those tests. This test creates many instances, drives a subset
# into "infected" or "dead", and asserts others remain at their independent
# states.
# ===========================================================================

func test_tb006_many_instances_are_isolated() -> void:
	var machines: Array[EnemyStateMachine] = []
	for i in 20:
		machines.append(_make_machine())

	# Drive even-indexed machines to infected, odd-indexed to dead via direct death.
	for i in machines.size():
		var m: EnemyStateMachine = machines[i]
		if i % 2 == 0:
			m.apply_weaken_event()
			m.apply_infection_event()
		else:
			m.apply_death_event()

	# Verify expected distribution.
	for i in machines.size():
		var m: EnemyStateMachine = machines[i]
		var state: String = _state_of(m)
		if i % 2 == 0:
			_assert_state(
				"infected",
				state,
				"tb006_even_index_infected_" + str(i) + " — even-indexed machine should be infected"
			)
		else:
			_assert_state(
				"dead",
				state,
				"tb006_odd_index_dead_" + str(i) + " — odd-indexed machine should be dead"
			)

	# Now reset only the first half; second half must remain unchanged.
	for i in machines.size() / 2:
		var m_reset: EnemyStateMachine = machines[i]
		m_reset.reset()

	for i in machines.size():
		var m_check: EnemyStateMachine = machines[i]
		var state_after: String = _state_of(m_check)
		if i < machines.size() / 2:
			_assert_state(
				"idle",
				state_after,
				"tb006_reset_first_half_idle_" + str(i) + " — reset machines return to 'idle'"
			)
		else:
			var expected: String = "infected" if i % 2 == 0 else "dead"
			_assert_state(
				expected,
				state_after,
				"tb006_second_half_unchanged_" + str(i) + " — machines not reset retain prior state"
			)


