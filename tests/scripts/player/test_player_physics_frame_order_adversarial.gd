func _require_jump_buffer_export(player: CharacterBody3D, test_name: String) -> bool:
	if not ("jump_buffer_time" in player):
		_fail_missing_api(test_name, "jump_buffer_time export missing")
		return false
	return true


func _require_mask_accessor(player: CharacterBody3D, test_name: String) -> bool:
	if not player.has_method("get_one_way_collision_mask"):
		_fail_missing_api(test_name, "get_one_way_collision_mask() missing")
		return false
	return true


func _airborne_frames_with_buffer_set(player: CharacterBody3D, air_frames: int) -> bool:
	_press_jump_once()
	for _i in range(3):
		_release_all_input()
		_step_player(player, PHYSICS_STEP)
		if not player.is_on_floor():
			break
	if player.is_on_floor():
		return false
	_press_jump_once()
	for _i in range(air_frames):
		if player.is_on_floor():
			player.global_position.y += 0.4
			player.velocity = Vector3(0.0, -0.35, 0.0)
		_release_all_input()
		_step_player(player, PHYSICS_STEP)
	return not player.is_on_floor()


func _count_upward_spikes(player: CharacterBody3D, frame_budget: int) -> int:
	var spikes: int = 0
	var was_low: bool = true
	for _i in range(frame_budget):
		_release_all_input()
		_step_player(player, PHYSICS_STEP)
		var vy: float = _player_vy(player)
		if was_low and vy > UPWARD_VY_EPS:
			spikes += 1
			was_low = false
		elif vy < VY_ZERO_EPS:
			was_low = true
	return spikes


