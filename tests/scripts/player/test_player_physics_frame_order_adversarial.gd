func test_tb_pfo_001_buffer_expired_before_landing_no_buffered_jump() -> void:
	# VULNERABILITY: Off-by-one on timer decrement lets buffer survive past jump_buffer_time.
	var harness: Dictionary = _load_sandbox_harness()
	if harness.is_empty():
		_fail("tb_pfo_001", "sandbox harness unavailable")
		return
	var player: CharacterBody3D = harness["player"] as CharacterBody3D
	if not _require_jump_buffer_export(player, "tb_pfo_001"):
		_teardown_sandbox(harness)
		return
	_apply_player_props(player, {"jump_buffer_time": JUMP_BUFFER_DEFAULT})
	if not _settle_on_floor(player, Vector3(0.0, 1.0, 0.0)):
		_teardown_sandbox(harness)
		_fail("tb_pfo_001", "player did not settle")
		return
	_press_jump_once()
	for _i in range(3):
		_release_all_input()
		_step_player(player, PHYSICS_STEP)
	if not _airborne_frames_with_buffer_set(player, BUFFER_EXPIRE_FRAMES):
		_teardown_sandbox(harness)
		_fail("tb_pfo_001", "could not keep player airborne through buffer window")
		return
	var saw_upward_on_landing: bool = false
	for _i in range(50):
		_release_all_input()
		var was_airborne: bool = not player.is_on_floor()
		_step_player(player, PHYSICS_STEP)
		if player.is_on_floor() and was_airborne and _player_vy(player) > UPWARD_VY_EPS:
			saw_upward_on_landing = true
			break
	_assert_false(
		saw_upward_on_landing,
		"tb_pfo_001_no_buffered_jump_after_0_1s_airborne_expiry"
	)
	_teardown_sandbox(harness)


