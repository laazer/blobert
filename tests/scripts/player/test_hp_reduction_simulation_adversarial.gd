# Minimal grounded state — chunk attached, HP must be set explicitly per AC-60.4.
func _make_grounded(vx: float, vy: float, has_chunk: bool) -> MovementSimulation.MovementState:
	var s: MovementSimulation.MovementState = MovementSimulation.MovementState.new()
	s.velocity = Vector2(vx, vy)
	s.is_on_floor = true
	s.has_chunk = has_chunk
	return s


# Minimal airborne state — chunk attached, HP must be set explicitly per AC-60.4.
func _make_airborne(vx: float, vy: float, has_chunk: bool) -> MovementSimulation.MovementState:
	var s: MovementSimulation.MovementState = MovementSimulation.MovementState.new()
	s.velocity = Vector2(vx, vy)
	s.is_on_floor = false
	s.has_chunk = has_chunk
	return s


# Wall-clinging state for tests that fire wall jump or cling-related scenarios.
# jump_consumed must be false for cling/wall-jump to be eligible.
func _make_clinging(cling_timer_val: float) -> MovementSimulation.MovementState:
	var s: MovementSimulation.MovementState = MovementSimulation.MovementState.new()
	s.velocity = Vector2(0.0, 20.0)
	s.is_on_floor = false
	s.is_wall_clinging = true
	s.cling_timer = cling_timer_val
	s.jump_consumed = false
	s.has_chunk = true
	return s


# ---------------------------------------------------------------------------
# GAP-01 — All 9 MovementState fields verified on a single detach frame
#
# Vulnerability: the primary suite verifies current_hp and has_chunk in
# isolation. A buggy implementation could zero, corrupt, or cross-assign any
# of the other 7 fields inside step 18. This test uses a fully active prior
# state (non-zero velocity, active coyote window, jump_consumed=true, custom
# current_hp) and verifies every field of the result independently.
# AC-56.3 (same frame), AC-56.4 (no other fields affected), AC-54.2 (9 fields)
# ---------------------------------------------------------------------------

func test_gap01_all_9_fields_on_detach_frame() -> void:
	# AC-56.3, AC-56.4 — All 9 MovementState fields on a single detach frame.
	var sim: MovementSimulation = MovementSimulation.new()
	# defaults: hp_cost_per_detach=25.0, min_hp=0.0, gravity=980.0

	# Fully active prior state — maximise chance of cross-field contamination.
	var prior: MovementSimulation.MovementState = MovementSimulation.MovementState.new()
	prior.velocity = Vector2(50.0, -100.0)   # moving right and ascending
	prior.is_on_floor = false
	prior.coyote_timer = 0.05               # active coyote window
	prior.jump_consumed = true              # jump already used — ensures no regular/wall jump
	prior.is_wall_clinging = false
	prior.cling_timer = 0.0
	prior.has_chunk = true
	prior.current_hp = 80.0               # AC-60.4: explicit non-default

	# Detach fires: has_chunk=true + detach_just_pressed=true.
	# jump_consumed=true means no jump path fires; no wall cling active.
	var result: MovementSimulation.MovementState = sim.simulate(prior, 1.0, false, false, false, 0.0, [true, false], 0.016)

	# --- Field 9 (new): current_hp ---
	# Formula: max(0.0, 80.0 - 25.0) = 55.0
	_assert_exact(result.current_hp, 55.0,
		"gap01 — field9: result.current_hp = max(0.0, 80.0-25.0) = 55.0")

	# --- Field 8: has_chunk ---
	_assert_false(result.has_chunk,
		"gap01 — field8: result.has_chunk=false (detach fired)")

	# --- Field 1: velocity.x ---
	# Case 3 (airborne + axis=1.0): accelerate toward max_speed.
	# move_toward(50.0, 200.0, 800.0*0.016) = move_toward(50.0, 200.0, 12.8) = 62.8
	_assert_approx(result.velocity.x, 62.8,
		"gap01 — field1: velocity.x accelerates toward max_speed on detach frame")

	# --- Field 2: velocity.y ---
	# No jump (jump_consumed=true), so carry prior.vy then add gravity.
	# No cling active, normal gravity: -100.0 + 980.0*0.016 = -100.0 + 15.68 = -84.32
	_assert_approx(result.velocity.y, -84.32,
		"gap01 — field2: velocity.y = -100.0 + gravity*delta = -84.32")

	# --- Field 3: is_on_floor ---
	# Pass-through from prior_state.is_on_floor = false.
	_assert_false(result.is_on_floor,
		"gap01 — field3: is_on_floor carries forward as false")

	# --- Field 4: coyote_timer ---
	# Airborne + not on floor: max(0.0, 0.05 - 0.016) = 0.034
	_assert_approx(result.coyote_timer, 0.034,
		"gap01 — field4: coyote_timer decrements by delta: max(0.0, 0.05-0.016)=0.034")

	# --- Field 5: jump_consumed ---
	# Airborne + no jump fires: carries forward as true.
	_assert_true(result.jump_consumed,
		"gap01 — field5: jump_consumed carries forward as true (no jump fired)")

	# --- Field 6: is_wall_clinging ---
	# Not on wall (is_on_wall=false), so cling_eligible=false → is_wall_clinging=false.
	_assert_false(result.is_wall_clinging,
		"gap01 — field6: is_wall_clinging=false (not on wall this frame)")

	# --- Field 7: cling_timer ---
	# cling_eligible=false → cling_timer reset to 0.0.
	_assert_exact(result.cling_timer, 0.0,
		"gap01 — field7: cling_timer=0.0 (cling not eligible)")


# ---------------------------------------------------------------------------
# GAP-02 — HP + regular jump same frame
#
# Vulnerability: The primary suite confirms HP reduction on a detach frame,
# but never fires a regular jump simultaneously. An implementation that
# applies step 18 before step 11 (wrong order) or that uses `result.has_chunk`
# as the detach condition instead of `detach_eligible` could produce wrong
# results when the jump branch clears or modifies state fields. This test
# verifies: jump impulse is correct AND HP is reduced on the same call.
# AC-56.3 (same frame as detach), AC-56.4 (non-HP fields unaffected by HP step)
# ---------------------------------------------------------------------------

func test_gap02_hp_plus_regular_jump_same_frame() -> void:
	# AC-56.3 — HP + jump fire simultaneously; both results correct.
	var sim: MovementSimulation = MovementSimulation.new()
	# gravity=980.0, jump_height=120.0 → impulse = -sqrt(2*980*120) = -sqrt(235200) ≈ -485.18
	# After gravity step: -485.18 + 980.0*0.016 = -485.18 + 15.68 = -469.50

	var prior: MovementSimulation.MovementState = _make_grounded(0.0, 0.0, true)
	prior.coyote_timer = 0.1   # floor frame sets this, but prior.is_on_floor=true is enough
	prior.current_hp = 100.0  # AC-60.4

	# jump_just_pressed=true + detach_just_pressed=true simultaneously.
	var result: MovementSimulation.MovementState = sim.simulate(prior, 0.0, true, true, false, 0.0, [true, false], 0.016)

	# HP reduction must have fired:
	_assert_exact(result.current_hp, 75.0,
		"gap02 — HP reduces from 100.0 to 75.0 on same frame as jump")

	# Detach must have fired:
	_assert_false(result.has_chunk,
		"gap02 — has_chunk=false: detach fired on same frame as jump")

	# Jump impulse must have fired:
	# result.velocity.y = -sqrt(2*980*120) + 980*0.016 ≈ -469.50
	var expected_vy: float = -sqrt(2.0 * 980.0 * 120.0) + 980.0 * 0.016
	_assert_approx(result.velocity.y, expected_vy,
		"gap02 — jump impulse correct on same frame as HP detach")

	# jump_consumed must be true (set by jump path):
	_assert_true(result.jump_consumed,
		"gap02 — jump_consumed=true after regular jump on detach frame")


# ---------------------------------------------------------------------------
# GAP-03 — HP + wall jump same frame
#
# Vulnerability: Wall jump skips the horizontal formula (step 12). An
# implementation that conflates the wall jump branch exit with early return
# could skip step 18. This test fires wall jump + detach simultaneously.
# AC-56.3, AC-56.4
# ---------------------------------------------------------------------------

func test_gap03_hp_plus_wall_jump_same_frame() -> void:
	# AC-56.3 — Wall jump fires AND HP reduces on the same simulate() call.
	var sim: MovementSimulation = MovementSimulation.new()
	# wall_jump_height=100.0, gravity=980.0
	# vertical impulse = -sqrt(2*980*100) = -sqrt(196000) ≈ -442.72
	# After gravity: -442.72 + 980.0*0.016 = -442.72 + 15.68 = -427.04
	# horizontal: wall_normal_x * wall_jump_horizontal_speed = 1.0 * 180.0 = 180.0

	var prior: MovementSimulation.MovementState = _make_clinging(0.25)
	prior.current_hp = 100.0  # AC-60.4

	# jump_just_pressed=true (wall jump eligible: prior.is_wall_clinging=true + not consumed)
	# jump_pressed=true so jump cut does not fire and clamp the impulse.
	# detach_just_pressed=true simultaneously.
	# is_on_wall=true (stay on wall), wall_normal_x=1.0 (wall on left → normal points right).
	var result: MovementSimulation.MovementState = sim.simulate(prior, -1.0, true, true, true, 1.0, [true, false], 0.016)

	# HP reduction must have fired:
	_assert_exact(result.current_hp, 75.0,
		"gap03 — HP reduces from 100.0 to 75.0 on same frame as wall jump")

	# Detach must have fired:
	_assert_false(result.has_chunk,
		"gap03 — has_chunk=false: detach fired on same frame as wall jump")

	# Wall jump impulse must have fired (velocity.x = normal_x * speed):
	_assert_approx(result.velocity.x, 180.0,
		"gap03 — wall jump horizontal impulse correct on detach frame")

	var expected_vy: float = -sqrt(2.0 * 980.0 * 100.0) + 980.0 * 0.016
	_assert_approx(result.velocity.y, expected_vy,
		"gap03 — wall jump vertical impulse correct on detach frame")


# ---------------------------------------------------------------------------
# GAP-04 — HP reduction during active wall cling: cling fields carry forward
#
# Vulnerability: Step 18 writes result.current_hp. An implementation that
# accidentally reads or overwrites result.is_wall_clinging or result.cling_timer
# in step 18 would corrupt the carry-forward of those fields. Differential test:
# detach + cling vs. no-detach + cling — all non-HP cling fields must be equal.
# AC-56.4 (no other fields affected), SPEC-57 (carry-forward path)
# ---------------------------------------------------------------------------

func test_gap04_hp_reduction_during_active_wall_cling() -> void:
	# AC-56.4 — HP reduction does not disturb cling fields.
	var sim: MovementSimulation = MovementSimulation.new()

	# Reference: active cling, no detach.
	var prior_ref: MovementSimulation.MovementState = _make_clinging(0.3)
	prior_ref.current_hp = 100.0  # AC-60.4
	var result_ref: MovementSimulation.MovementState = sim.simulate(prior_ref, -1.0, false, false, true, 1.0, [false, false], 0.016)

	# Detach variant: identical state, only detach_just_pressed=true.
	var prior_det: MovementSimulation.MovementState = _make_clinging(0.3)
	prior_det.current_hp = 100.0  # AC-60.4
	var result_det: MovementSimulation.MovementState = sim.simulate(prior_det, -1.0, false, false, true, 1.0, [true, false], 0.016)

	# HP must differ (detach reduces it).
	_assert_exact(result_det.current_hp, 75.0,
		"gap04 — HP reduces to 75.0 during active wall cling detach")

	# All cling fields must match the no-detach reference.
	_assert_true(result_det.is_wall_clinging == result_ref.is_wall_clinging,
		"gap04 — is_wall_clinging identical between detach and no-detach during cling")
	_assert_approx(result_det.cling_timer, result_ref.cling_timer,
		"gap04 — cling_timer identical between detach and no-detach during cling")

	# Velocity fields must also match (cling gravity applied equally).
	_assert_approx(result_det.velocity.y, result_ref.velocity.y,
		"gap04 — velocity.y identical (cling gravity) between detach and no-detach")


# ---------------------------------------------------------------------------
# GAP-05 — HP at hp_cost_per_detach - epsilon (just above cost boundary)
#
# Vulnerability: An off-by-one implementation might clamp to min_hp when the
# subtraction result is just above 0.0. This test places current_hp just above
# cost (cost=25.0, prior_hp=25.0 + EPSILON). The subtraction result is EPSILON
# (> 0.0 = min_hp), so NO clamp should apply.
# AC-58.1 (subtraction result >= min_hp → no clamp)
# ---------------------------------------------------------------------------

func test_gap05_hp_just_above_cost_boundary() -> void:
	# AC-58.1 — Subtraction result just above 0.0; floor clamp must NOT fire.
	# Vulnerability: an implementation that uses >= instead of > in the clamp
	# guard would clamp this boundary case incorrectly.
	var sim: MovementSimulation = MovementSimulation.new()
	# defaults: hp_cost_per_detach=25.0, min_hp=0.0

	var prior: MovementSimulation.MovementState = _make_airborne(0.0, 0.0, true)
	# prior_hp = 25.0 + EPSILON: subtraction = EPSILON > 0.0 = min_hp → no clamp.
	prior.current_hp = 25.0 + EPSILON  # AC-60.4

	var result: MovementSimulation.MovementState = sim.simulate(prior, 0.0, false, false, false, 0.0, [true, false], 0.016)

	# result = max(0.0, (25.0 + EPSILON) - 25.0) = max(0.0, EPSILON) = EPSILON
	# Must be > 0.0 and approximately EPSILON (not clamped to 0.0).
	_assert_true(result.current_hp > 0.0,
		"gap05 — result.current_hp > 0.0: no premature floor clamp at boundary")
	_assert_approx(result.current_hp, EPSILON,
		"gap05 — result.current_hp ≈ EPSILON: subtraction not clamped when above floor")


