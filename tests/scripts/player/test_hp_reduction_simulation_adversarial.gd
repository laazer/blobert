#
# Vulnerability: HP reduction reads only hp_cost_per_detach and min_hp (both
# new). The 12 pre-existing config vars (max_speed, gravity, acceleration,
# friction, air_deceleration, jump_height, coyote_time, jump_cut_velocity,
# cling_gravity_scale, max_cling_time, wall_jump_height,
# wall_jump_horizontal_speed) must have zero effect on the HP formula. This
# test confirms by setting them all to extreme values and verifying HP = 75.0.
# AC-55.5 (max_hp not read), AC-56.4 (HP step reads only its own vars)
# ---------------------------------------------------------------------------

func test_gap09_all_12_preexisting_config_vars_mutated() -> void:
	# AC-56.4 — HP formula is isolated from all 12 pre-existing config vars.
	var sim: MovementSimulation = MovementSimulation.new()

	# Mutate all 12 pre-existing config vars to extreme values.
	sim.max_speed = 0.0
	sim.acceleration = 0.0
	sim.friction = 0.0
	sim.air_deceleration = 0.0
	sim.gravity = 0.0            # zero gravity: velocity.y stays at prior
	sim.jump_height = 0.0
	sim.coyote_time = 0.0
	sim.jump_cut_velocity = 0.0
	sim.cling_gravity_scale = 0.0
	sim.max_cling_time = 0.0
	sim.wall_jump_height = 0.0
	sim.wall_jump_horizontal_speed = 0.0

	# HP config vars use defaults: hp_cost_per_detach=25.0, min_hp=0.0.

