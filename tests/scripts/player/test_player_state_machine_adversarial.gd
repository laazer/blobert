func _require_machine(test_name: String) -> Object:
	var machine: Object = _make_machine()
	if machine == null:
		_fail_missing_module(test_name)
		return null
	if not _has_fsm_api(machine):
		_fail(test_name + "_api", "PlayerStateMachine missing required FSM API")
		return null
	return machine


func _require_ctx(test_name: String) -> Object:
	var ctx: Object = _ctx_floor_idle()
	if ctx == null:
		_fail_missing_module(test_name)
		return null
	return ctx


# ---------------------------------------------------------------------------
# EC-1 — DEAD terminal until reset()
# ---------------------------------------------------------------------------

func test_ec1_dead_blocks_all_non_dead_transitions() -> void:
	var machine: Object = _require_machine("ec1_dead_blocks")
	if machine == null:
		return
	machine.transition(STATE_DEAD)
	for target in ALL_STATES:
		if target == STATE_DEAD:
			continue
		var ok: bool = machine.transition(target)
		_assert_false(
			ok,
			"ec1_dead_to_" + str(target) + "_denied — G-DEAD blocks transition from DEAD"
		)
		_assert_eq_int(
			STATE_DEAD,
			_state_of(machine),
			"ec1_dead_persists_after_" + str(target) + " — state stays DEAD"
		)


func test_ec1_dead_same_state_noop_allowed() -> void:
	var machine: Object = _require_machine("ec1_dead_noop")
	if machine == null:
		return
	machine.transition(STATE_DEAD)
	machine.update(0.02)
	var before_timer: float = _timer_of(machine)
	var ok: bool = machine.transition(STATE_DEAD)
	_assert_true(ok, "ec1_dead_to_dead_noop — same-state DEAD→DEAD returns true")
	_assert_eq_int(STATE_DEAD, _state_of(machine), "ec1_dead_noop_state")
	_assert_approx(
		before_timer,
		_timer_of(machine),
		"ec1_dead_noop_timer — same-state does not reset timer"
	)


func test_ec1_reset_required_to_leave_dead() -> void:
	var machine: Object = _require_machine("ec1_reset_required")
	if machine == null:
		return
	machine.transition(STATE_DEAD)
	machine.reset()
	_assert_eq_int(STATE_IDLE, _state_of(machine), "ec1_reset_leaves_dead — reset() → IDLE")
	var ok: bool = machine.transition(STATE_WALK)
	_assert_true(ok, "ec1_walk_after_reset — transitions allowed after reset()")


