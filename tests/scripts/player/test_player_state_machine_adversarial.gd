func test_adv_can_transition_matches_transition_denials() -> void:
	var machine: Object = _require_machine("adv_guard_consistency")
	if machine == null:
		return
	machine.transition(STATE_DEAD)
	for target in ALL_STATES:
		if target == STATE_DEAD:
			continue
		var can: bool = machine.can_transition_to(target)
		var ok: bool = machine.transition(target)
		_assert_true(
			can == ok,
			"adv_guard_match_dead_" + str(target) + " — can_transition_to matches transition() from DEAD"
		)
	machine.reset()
	machine.transition(STATE_HURT)
	for target in ALL_STATES:
		if target == STATE_HURT:
			continue
		var probe: Object = _make_machine()
		if probe == null:
			_fail_missing_module("adv_guard_hurt_probe")
			return
		probe.transition(STATE_HURT)
		var can_h: bool = probe.can_transition_to(target)
		var ok_h: bool = probe.transition(target)
		_assert_true(
			can_h == ok_h,
			"adv_guard_match_hurt_" + str(target) + " — can_transition_to matches transition() from HURT"
		)


