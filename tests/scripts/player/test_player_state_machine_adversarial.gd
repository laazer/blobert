func test_adv_many_instances_are_isolated() -> void:
	var machines: Array = []
	for i in 20:
		var m: Object = _require_machine("adv_isolation_" + str(i))
		if m == null:
			return
		machines.append(m)
	for i in machines.size():
		var m: Object = machines[i]
		if i % 2 == 0:
			m.transition(STATE_JUMP)
		else:
			m.transition(STATE_HURT)
			m.notify_damage_taken()
			m.sync_from_context(_ctx_floor_idle())
	for i in machines.size() / 2:
		machines[i].reset()
	for i in machines.size():
		var m: Object = machines[i]
		if i < machines.size() / 2:
			_assert_eq_int(STATE_IDLE, _state_of(m), "adv_isolation_reset_" + str(i) + " — reset half stay IDLE")
		elif i % 2 == 0:
			_assert_eq_int(STATE_JUMP, _state_of(m), "adv_isolation_jump_" + str(i) + " — unreset JUMP persists")
		else:
			_assert_eq_int(STATE_HURT, _state_of(m), "adv_isolation_hurt_" + str(i) + " — unreset HURT persists")


