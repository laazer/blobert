# ===========================================================================
# ADV-EAC-05 — Death latch does not allow speed_scale to change afterward.
#
# VULNERABILITY: AC-7.3 says "no play(), stop(), or speed_scale call" after
# death is latched. The primary suite (EAC-11) only asserts play_call_count
# does not increase. It does not verify that speed_scale remains unmodified.
# An implementation might check the latch only for play() but still execute a
# speed_scale assignment elsewhere (e.g., in the weakened branch that runs
# before the death check in a naive if/elif chain).
#
# This test drives through weakened (speed_scale=0.5), then through dead (which
# resets speed_scale=1.0), latches, then verifies a subsequent tick does NOT
# change speed_scale.
# ===========================================================================

func test_adv_eac_05_death_latch_prevents_speed_scale_changes() -> void:
	var controller = _new_controller("ADV-EAC-05")
	if controller == null:
		return

	var anim_stub := StubAnimationPlayer.new()
	var sm_stub := StubStateMachine.new()
	sm_stub._state = "weakened"

	var parent := StubParent.new()
	parent.velocity = Vector3.ZERO

	parent.add_child(controller)
	controller.animation_player = anim_stub
	controller.state_machine = sm_stub
	controller._ready()

	# Tick in weakened state to establish speed_scale = 0.5.
	_tick(controller)
	_assert_eq_float(
		0.5,
		anim_stub.speed_scale,
		"ADV-EAC-05: precondition — weakened tick sets speed_scale = 0.5"
	)

	# Transition to dead.
	sm_stub._state = "dead"
	_tick(controller)
	_assert_true(
		controller._death_latched,
		"ADV-EAC-05: precondition — _death_latched = true after dead tick"
	)
	_assert_eq_float(
		1.0,
		anim_stub.speed_scale,
		"ADV-EAC-05: death tick restores speed_scale = 1.0 (AC-7.5)"
	)

	# Record speed_scale after death latch.
	var speed_after_latch: float = anim_stub.speed_scale

	# Tick again — must not mutate speed_scale.
	_tick(controller)
	_assert_eq_float(
		speed_after_latch,
		anim_stub.speed_scale,
		"ADV-EAC-05: subsequent tick after death latch must not change speed_scale"
	)
	parent.free()


# ===========================================================================
# ADV-EAC-06 — AnimationPlayer current_animation "" while _hit_active triggers exit.
#
# VULNERABILITY: The spec says hit completion is detected when is_playing() == false
# OR current_animation != "Hit". If current_animation is reset to "" externally
# (e.g., by another system calling stop()), the check `current_animation != "Hit"`
# evaluates to true while is_playing() might still be true. An implementation that
# only checks is_playing() and ignores current_animation would NOT exit hit mode
# in this scenario. An implementation that checks both (OR logic) would correctly
# exit hit mode.
#
# This test probes which condition the implementation actually uses by simulating
# the case where current_animation is cleared to "" while is_playing() remains true.
# ===========================================================================

func test_adv_eac_06_hit_exits_when_current_animation_cleared_to_empty() -> void:
	var arr := _make_controller("ADV-EAC-06", "active", Vector3.ZERO)
	if arr.is_empty():
		return
	var controller = arr[0]
	var anim_stub: StubAnimationPlayer = arr[1]
	var parent: StubParent = arr[3]

	_tick(controller)
	controller.trigger_hit_animation()

	# Verify hit is active.
	_assert_true(
		controller._hit_active,
		"ADV-EAC-06: precondition — _hit_active = true after trigger_hit_animation()"
	)

	# Externally clear current_animation while is_playing() remains true.
	# This simulates an external system calling stop() or resetting animation state.
	anim_stub.current_animation = ""
	# is_playing() is still true (not called simulate_clip_end).

	anim_stub.play_call_count = 0
	_tick(controller)

	# If the controller checks current_animation != "Hit" as a completion condition,
	# it should now exit hit mode (current_animation "" != "Hit" is true).
	# The test documents the expected behavior: exit hit when current_animation != "Hit".
	_assert_false(
		controller._hit_active,
		"ADV-EAC-06: current_animation cleared to '' while _hit_active — controller exits hit mode (current_animation != 'Hit' satisfies completion condition)"
	)
	parent.free()


