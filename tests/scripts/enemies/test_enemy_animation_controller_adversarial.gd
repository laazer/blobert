# ADV-EAC-13 — Wrong-case state string falls through to Idle fallback.
#
# VULNERABILITY: Primary suite only tests lowercase canonical states. The spec
# says state string matching is case-sensitive (the resolution table uses exact
# lowercase literals). An implementation using case-insensitive comparison
# (e.g., state.to_lower() == "active") would not expose this bug. The correct
# behavior is that "ACTIVE" or "Active" are unknown states and fall through to
# the Idle fallback at speed 1.0 — even with non-zero velocity.
# ===========================================================================

func test_adv_eac_13_uppercase_state_string_falls_to_idle_fallback() -> void:
	# "ACTIVE" is not a canonical state; velocity is set above threshold.
	# Correct: Idle (fallback) at speed 1.0.
	# Wrong (case-insensitive bug): Walk at speed 1.0.
	var arr := _make_controller("ADV-EAC-13", "ACTIVE", Vector3(0.5, 0.0, 0.0))
	if arr.is_empty():
		return
	var controller = arr[0]
	var anim_stub: StubAnimationPlayer = arr[1]
	var parent: StubParent = arr[3]

	_tick(controller)

	_assert_eq_string(
		"Idle",
		anim_stub.last_played_name,
		"ADV-EAC-13: state 'ACTIVE' (wrong casing) → fallback 'Idle', not 'Walk' (case-sensitive matching)"
	)
	_assert_eq_float(
		1.0,
		anim_stub.speed_scale,
		"ADV-EAC-13: state 'ACTIVE' fallback → speed_scale = 1.0"
	)
	parent.free()


# ===========================================================================
# ADV-EAC-14 — Large velocity value does not crash or produce wrong result.
#
# VULNERABILITY: velocity.length() uses a square root. For extreme values like
# Vector3(1000, 1000, 1000), length ≈ 1732. This is far above any threshold.
# A naive integer-overflow bug or unexpected branching at extreme magnitudes
# could cause the controller to fall through to Idle instead of Walk.
# ===========================================================================

func test_adv_eac_14_large_velocity_resolves_to_walk() -> void:
	var arr := _make_controller("ADV-EAC-14", "active", Vector3(1000.0, 1000.0, 1000.0))
	if arr.is_empty():
		return
	var controller = arr[0]
	var anim_stub: StubAnimationPlayer = arr[1]
	var parent: StubParent = arr[3]

	_tick(controller)

	_assert_eq_string(
		"Walk",
		anim_stub.last_played_name,
		"ADV-EAC-14: velocity Vector3(1000,1000,1000) with state 'active' → play('Walk', ...) (no overflow)"
	)
	parent.free()


# ===========================================================================
# ADV-EAC-15 — 60-tick simulation with state change at tick 30 produces
#              exactly 2 play() calls total (one on tick 1, one on tick 30).
#
# VULNERABILITY: Primary EAC-NF1 only tests a constant state for 60 ticks
# (1 play call). No test verifies that a single state change mid-simulation
# produces exactly 2 play calls. An implementation that is either too eager
# (calls play() every frame) or too lazy (misses the state-change transition)
# would be caught here.
#
# Scenario: ticks 1–29 idle+still=Idle (1 play on tick 1), ticks 30–60
# active+moving=Walk (1 play on tick 30). Total: 2 play() calls.
# ===========================================================================

func test_adv_eac_15_single_state_change_mid_simulation_produces_two_play_calls() -> void:
	var controller = _new_controller("ADV-EAC-15")
	if controller == null:
		return

	var anim_stub := StubAnimationPlayer.new()
	var sm_stub := StubStateMachine.new()
	sm_stub._state = "idle"

	var parent := StubParent.new()
	parent.velocity = Vector3.ZERO

	parent.add_child(controller)
	controller.animation_player = anim_stub
	controller.state_machine = sm_stub
	controller._ready()

	# Ticks 1–29: idle, still → Idle.
	for _i in 29:
		_tick(controller)

	var count_before_change: int = anim_stub.play_call_count
	_assert_eq_int(
		1,
		count_before_change,
		"ADV-EAC-15: after 29 ticks of constant idle+still → exactly 1 play() call"
	)

	# Transition: active + moving → Walk.
	sm_stub._state = "active"
	parent.velocity = Vector3(0.5, 0.0, 0.0)

	# Ticks 30–60: active, moving → Walk.
	for _i in 31:
		_tick(controller)

	_assert_eq_int(
		2,
		anim_stub.play_call_count,
		"ADV-EAC-15: 60 ticks with one state change at tick 30 → exactly 2 play() calls total"
	)
	_assert_eq_string(
		"Walk",
		anim_stub.last_played_name,
		"ADV-EAC-15: final clip after state change is 'Walk'"
	)
	parent.free()


# ===========================================================================
# ADV-EAC-16 — Negative blend_time passed verbatim to play().
#
# VULNERABILITY: The spec says blend_time export value is used for transitions.
# An implementation that clamps negative values to 0.0 diverges from the spec's
# verbatim pass-through intent. In Godot 4, AnimationPlayer.play() with a
# negative blend_time uses the AnimationPlayer's own default blend. While either
# behavior could be considered valid, the test documents the expected contract:
# verbatim pass-through (no clamping). If the Implementation Agent clamps,
# this test will fail — exposing the divergence so the spec can be clarified.
# ===========================================================================

func test_adv_eac_16_negative_blend_time_passed_verbatim_to_play() -> void:
	var controller = _new_controller("ADV-EAC-16")
	if controller == null:
		return

	var anim_stub := StubAnimationPlayer.new()
	var sm_stub := StubStateMachine.new()
	sm_stub._state = "idle"

	var parent := StubParent.new()
	parent.velocity = Vector3.ZERO

	parent.add_child(controller)
	controller.animation_player = anim_stub
	controller.state_machine = sm_stub
	controller.blend_time = -1.0
	controller._ready()

	_tick(controller)

	_assert_eq_float(
		-1.0,
		anim_stub.last_played_blend,
		"ADV-EAC-16: blend_time = -1.0 passed verbatim to play() — no clamping per spec"
	)
	parent.free()


