# ===========================================================================
# ADV-EAC-12 — State becomes dead during hit active window (pre-clip-end) —
#              Death must NOT trigger while hit clip is still playing.
#
# VULNERABILITY: EAC-16 tests that after the Hit clip FINISHES, Death triggers
# correctly. But no test verifies the scenario where the enemy dies DURING the
# hit (is_playing() still true). AC-6.4 says the state dispatch is suppressed
# while _hit_active is true. This must include the Death branch — Death should
# not be triggered until hit completes.
#
# An implementation with separate early-exit for death in _physics_process
# (before the _hit_active check) would violate this by triggering Death
# mid-hit.
# ===========================================================================

func test_adv_eac_12_dead_during_hit_active_window_does_not_trigger_death() -> void:
	var arr := _make_controller("ADV-EAC-12", "active", Vector3.ZERO)
	if arr.is_empty():
		return
	var controller = arr[0]
	var anim_stub: StubAnimationPlayer = arr[1]
	var sm_stub: StubStateMachine = arr[2]
	var parent: StubParent = arr[3]

	_tick(controller)
	controller.trigger_hit_animation()

	_assert_true(
		controller._hit_active,
		"ADV-EAC-12: precondition — _hit_active = true after trigger_hit_animation()"
	)

	# Enemy dies while hit is still playing (is_playing() remains true).
	sm_stub._state = "dead"
	# Do NOT simulate_clip_end — hit is still active.
	anim_stub.play_call_count = 0

	_tick(controller)

	# Death must NOT be triggered mid-hit.
	_assert_false(
		controller._death_latched,
		"ADV-EAC-12: state becomes 'dead' during active hit (clip still playing) — _death_latched must remain false"
	)
	_assert_eq_int(
		0,
		anim_stub.play_call_count,
		"ADV-EAC-12: no play() call while hit clip is still playing even when state is 'dead'"
	)
	_assert_true(
		controller._hit_active,
		"ADV-EAC-12: _hit_active remains true while hit clip is still playing"
	)
	parent.free()


