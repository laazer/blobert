func _load_script() -> bool:
	if _load_attempted:
		return _controller_script != null
	_load_attempted = true
	_controller_script = load(_CONTROLLER_PATH) as GDScript
	return _controller_script != null


func _new_controller(test_name: String) -> Object:
	if not _load_script():
		_fail(test_name, "implementation not found at " + _CONTROLLER_PATH)
		return null
	return _controller_script.new()


# ---------------------------------------------------------------------------
# Factory helper — mirrors the primary suite pattern.
# Returns [controller, anim_stub, sm_stub, parent] or [] if script missing.
# ---------------------------------------------------------------------------

func _make_controller(test_name: String, state: String = "idle", vel: Vector3 = Vector3.ZERO) -> Array:
	var controller = _new_controller(test_name)
	if controller == null:
		return []

	var anim_stub := StubAnimationPlayer.new()
	var sm_stub := StubStateMachine.new()
	sm_stub._state = state

	var parent := StubParent.new()
	parent.velocity = vel

	parent.add_child(controller)
	controller.animation_player = anim_stub
	controller.state_machine = sm_stub
	controller._ready()

	return [controller, anim_stub, sm_stub, parent]


func _tick(controller: Object) -> void:
	controller._physics_process(0.016)


# ===========================================================================
# ADV-EAC-01 — Empty string from get_state() falls through to Idle fallback.
#
# VULNERABILITY: The primary suite does not test get_state() == "". An
# implementation that uses `match state:` without an explicit `_:` catch-all,
# or that only checks known state strings with `if/elif` without a final `else`,
# could crash or produce undefined behavior (e.g., no play() call, leaving
# animation frozen from a previous state). An empty string is a valid return
# value if the state machine has not been initialized.
#
# AC-4.8 extends to the empty string case by the same "any other state string"
# rule. Confirmed in checkpoint run-2026-04-01-testbreak.md.
# ===========================================================================

func test_adv_eac_01_empty_state_string_falls_to_idle_fallback() -> void:
	var arr := _make_controller("ADV-EAC-01", "", Vector3.ZERO)
	if arr.is_empty():
		return
	var controller = arr[0]
	var anim_stub: StubAnimationPlayer = arr[1]
	var parent: StubParent = arr[3]

	_tick(controller)

	_assert_eq_string(
		"Idle",
		anim_stub.last_played_name,
		"ADV-EAC-01: empty state string '' → fallback play('Idle', ...); no crash"
	)
	_assert_eq_float(
		0.15,
		anim_stub.last_played_blend,
		"ADV-EAC-01: empty state string → blend_time is still 0.15"
	)
	_assert_eq_float(
		1.0,
		anim_stub.speed_scale,
		"ADV-EAC-01: empty state string → speed_scale = 1.0 (fallback speed)"
	)
	parent.free()


# ===========================================================================
# ADV-EAC-02 — blend_time mutated AFTER _ready() takes effect on next transition.
#
# VULNERABILITY: An implementation that reads `blend_time` once in `_ready()`
# and stores it in a local copy will not reflect post-ready mutations. The export
# contract (ACS-5 AC-5.4, AC-5.5) requires the live export value to be used.
# Primary EAC-20 sets blend_time BEFORE _ready(); this test sets it AFTER.
#
# If the implementation caches blend_time in _ready(), this test will fail
# because the play() call will still use 0.15 (cached) instead of 0.0 (mutated).
# ===========================================================================

func test_adv_eac_02_blend_time_mutated_after_ready_takes_effect() -> void:
	var controller = _new_controller("ADV-EAC-02")
	if controller == null:
		return

	var anim_stub := StubAnimationPlayer.new()
	var sm_stub := StubStateMachine.new()
	sm_stub._state = "idle"

	var parent := StubParent.new()
	parent.velocity = Vector3.ZERO

	parent.add_child(controller)
	controller.animation_player = anim_stub
	controller.state_machine = sm_stub
	# _ready() runs with default blend_time = 0.15
	controller._ready()

	# First tick primes the internal state.
	_tick(controller)

	# Now change blend_time AFTER _ready() and AFTER first tick.
	# Force a new transition by changing state.
	sm_stub._state = "active"
	controller.blend_time = 0.0

	# Trigger the transition by ticking.
	_tick(controller)

	_assert_eq_float(
		0.0,
		anim_stub.last_played_blend,
		"ADV-EAC-02: blend_time mutated to 0.0 after _ready() — subsequent play() uses new value 0.0"
	)
	parent.free()


