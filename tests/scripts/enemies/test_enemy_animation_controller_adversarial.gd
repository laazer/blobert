# (AC-6.6) must work correctly regardless of _prior_clip being "".
# ===========================================================================

func test_adv_eac_04_trigger_hit_before_first_tick_does_not_crash() -> void:
	var arr := _make_controller("ADV-EAC-04", "active", Vector3.ZERO)
	if arr.is_empty():
		return
	var controller = arr[0]
	var anim_stub: StubAnimationPlayer = arr[1]
	var parent: StubParent = arr[3]

	# Do NOT call _tick() first. Call trigger_hit_animation() immediately after _ready().
	controller.trigger_hit_animation()

	_assert_eq_string(
		"Hit",
		anim_stub.last_played_name,
		"ADV-EAC-04: trigger_hit_animation() before any tick → play('Hit', 0.0) called; no crash"
	)
	_assert_eq_float(
		0.0,
		anim_stub.last_played_blend,
		"ADV-EAC-04: trigger_hit before first tick → blend_time 0.0"
	)
