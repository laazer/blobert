# ===========================================================================
# ADV-EAC-10 — Multiple controller instances are isolated (no shared static state).
#
# VULNERABILITY: An implementation using a `static var` for _death_latched,
# _hit_active, or _current_clip would contaminate sibling controller instances.
# This test creates two controllers on separate stub parents, drives one to death
# and the other to idle, then verifies each has its own independent state.
# ===========================================================================

func test_adv_eac_10_two_instances_are_isolated() -> void:
	# Controller A: will be driven to dead.
	var arr_a := _make_controller("ADV-EAC-10-A", "idle", Vector3.ZERO)
	if arr_a.is_empty():
		return
	# Controller B: will stay in idle.
	var arr_b := _make_controller("ADV-EAC-10-B", "idle", Vector3.ZERO)
	if arr_b.is_empty():
		arr_a[3].free()
		return

	var ctrl_a = arr_a[0]
	var sm_a: StubStateMachine = arr_a[2]
	var parent_a: StubParent = arr_a[3]

	var ctrl_b = arr_b[0]
	var anim_b: StubAnimationPlayer = arr_b[1]
	var parent_b: StubParent = arr_b[3]

	# Drive A to dead.
	sm_a._state = "dead"
	_tick(ctrl_a)
	_assert_true(
		ctrl_a._death_latched,
		"ADV-EAC-10: controller A is death-latched after dead state tick"
	)

	# Drive B with a normal tick.
	_tick(ctrl_b)
	_assert_false(
		ctrl_b._death_latched,
		"ADV-EAC-10: controller B _death_latched is NOT affected by controller A's death latch"
	)
	_assert_false(
		ctrl_b._hit_active,
		"ADV-EAC-10: controller B _hit_active is NOT contaminated by controller A"
	)
	_assert_eq_string(
		"Idle",
		anim_b.last_played_name,
		"ADV-EAC-10: controller B plays Idle independently (unaffected by A's death)"
	)

	parent_a.free()
	parent_b.free()


