class_name MovementSimulationAdversarialTests
extends "res://tests/utils/test_utils.gd"

const EPSILON: float = 1e-4

var _pass_count: int = 0
var _fail_count: int = 0


func _make_state_with(vx: float, vy: float, on_floor: bool) -> MovementSimulation.MovementState:
	var s: MovementSimulation.MovementState = MovementSimulation.MovementState.new()
	s.velocity = Vector2(vx, vy)
	s.is_on_floor = on_floor
	return s


# ---------------------------------------------------------------------------
# [M1-001] TB-001 — NaN / Inf input_axis handling
#
# VULNERABILITY: The spec says input_axis behavior is only defined for [-1.0,
# 1.0]. If an implementation passes NaN or Inf directly into move_toward()
# without clamping, GDScript propagates NaN/Inf through arithmetic and the
# resulting velocity.x becomes NaN/Inf. This silently corrupts all future
# simulation state. These tests expose an implementation that does not sanitize
# input_axis before use.
#
# CHECKPOINT [M1-001] TB-001 — NaN/Inf input_axis handling
# Would have asked: Should simulate() silently clamp input_axis to [-1, 1],
# or should NaN/Inf produce deterministic (but possibly wrong) output, or
# should it be treated as 0.0 (safest default)?
# Assumption made: The conservative safe behavior is that NaN/Inf input_axis
# must NOT produce NaN/Inf in the output velocity. The spec guarantees the
# simulation is only called with valid input from the controller, so this is
# a robustness / defensive-programming test. We encode the assumption that
# NaN/Inf input must not propagate into output velocity.
# Confidence: Medium
# ---------------------------------------------------------------------------

func test_tb001_nan_input_axis_does_not_produce_nan_velocity_x() -> void:
	# CHECKPOINT: see TB-001 above
	var sim: MovementSimulation = MovementSimulation.new()
	var prior: MovementSimulation.MovementState = _make_state_with(0.0, 0.0, true)
	var nan_axis: float = 0.0 / 0.0  # GDScript produces NaN
	var result: MovementSimulation.MovementState = sim.simulate(prior, nan_axis, false, false, false, 0.0, [false, false], 0.016)
	# A robust implementation clamps or guards input_axis so velocity.x is finite.
	# If this fails, the implementation blindly passes NaN into move_toward().
	_assert_true(not is_nan(result.velocity.x),
		"tb001 — NaN input_axis must not produce NaN velocity.x")


func test_tb001_inf_input_axis_does_not_produce_inf_velocity_x() -> void:
	# CHECKPOINT: see TB-001 above
	var sim: MovementSimulation = MovementSimulation.new()
	var prior: MovementSimulation.MovementState = _make_state_with(0.0, 0.0, true)
	var inf_axis: float = INF
	var result: MovementSimulation.MovementState = sim.simulate(prior, inf_axis, false, false, false, 0.0, [false, false], 0.016)
	# move_toward(0.0, INF * 200.0, 12.8) = 12.8 in GDScript (move_toward step-limits).
	# However, a naive impl that sets target = INF * max_speed may produce INF.
	_assert_true(is_finite(result.velocity.x),
		"tb001 — INF input_axis must not produce INF velocity.x")


func test_tb001_negative_inf_input_axis_does_not_produce_neg_inf_velocity_x() -> void:
	# CHECKPOINT: see TB-001 above
	var sim: MovementSimulation = MovementSimulation.new()
	var prior: MovementSimulation.MovementState = _make_state_with(0.0, 0.0, true)
	var neg_inf_axis: float = -INF
	var result: MovementSimulation.MovementState = sim.simulate(prior, neg_inf_axis, false, false, false, 0.0, [false, false], 0.016)
