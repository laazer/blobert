func run_all() -> int:
	print("--- test_movement_simulation_adversarial.gd ---")
	_pass_count = 0
	_fail_count = 0

	# TB-001: NaN/Inf input_axis
	test_tb001_nan_input_axis_does_not_produce_nan_velocity_x()
	test_tb001_inf_input_axis_does_not_produce_inf_velocity_x()
	test_tb001_negative_inf_input_axis_does_not_produce_neg_inf_velocity_x()

	# TB-002: Negative delta
	test_tb002_negative_delta_does_not_move_velocity_x_away_from_target()
	test_tb002_negative_delta_does_not_add_upward_gravity()

	# TB-003: Zero config parameter boundaries
	test_tb003_max_speed_zero_keeps_velocity_x_at_zero_from_rest()
	test_tb003_max_speed_zero_decelerates_existing_velocity_to_zero()
	test_tb003_acceleration_zero_keeps_velocity_x_unchanged_grounded_input()
	test_tb003_acceleration_zero_keeps_velocity_x_unchanged_airborne_input()
	test_tb003_friction_zero_keeps_velocity_x_unchanged_grounded_no_input()
	test_tb003_gravity_zero_keeps_velocity_y_unchanged()

	# TB-004: Prior state is_on_floor not mutated
	test_tb004_prior_state_is_on_floor_not_mutated_when_passed_true()
	test_tb004_prior_state_is_on_floor_not_mutated_when_passed_false()

	# TB-005: Velocity exceeding max_speed as prior state
	test_tb005_velocity_x_above_max_speed_decelerates_with_positive_input()
	test_tb005_velocity_x_above_max_speed_does_not_exceed_prior_when_input_matches()
	test_tb005_velocity_x_far_below_neg_max_speed_decelerates_with_negative_input()

	# TB-006: Sign reversal
	test_tb006_full_speed_right_then_left_input_decelerates_correctly()
	test_tb006_sign_reversal_does_not_overshoot_zero_in_one_frame()
	test_tb006_sign_reversal_stays_within_max_speed_after_crossing_zero()

	# TB-007: Negative velocity.y (upward jump arc)
	test_tb007_negative_vy_increases_toward_zero_with_gravity()
	test_tb007_negative_vy_never_decreases_with_positive_gravity()
	test_tb007_negative_vy_eventually_becomes_positive_after_many_frames()

	# TB-008: Config mutation between calls
	test_tb008_max_speed_change_takes_effect_on_next_call()
	test_tb008_gravity_change_takes_effect_on_next_call()

	# TB-009: Steady-state convergence
	test_tb009_velocity_x_converges_to_max_speed_after_sufficient_frames()
	test_tb009_velocity_x_converges_to_neg_max_speed_with_negative_input()
	test_tb009_velocity_x_reaches_zero_from_rest_after_friction_drains_it()

	# TB-010: Air deceleration with negative velocity
	test_tb010_air_decel_decelerates_negative_velocity_toward_zero()
	test_tb010_air_decel_does_not_overshoot_zero_with_negative_velocity()

	# TB-011: Very large delta stress test
	test_tb011_very_large_delta_velocity_x_does_not_exceed_max_speed()
	test_tb011_very_large_delta_velocity_x_reaches_max_speed_in_one_step()
	test_tb011_very_large_delta_velocity_y_is_gravity_times_delta()
	test_tb011_very_large_delta_friction_stops_at_zero()

	# TB-012: Exact-step boundary
	test_tb012_acceleration_step_equals_remaining_distance_reaches_target_exactly()
	test_tb012_friction_step_equals_remaining_distance_reaches_zero_exactly()
	test_tb012_gravity_step_equals_remaining_distance_to_zero()

	# TB-013: Negative config parameter values
	test_tb013_negative_max_speed_does_not_crash_or_produce_nan()
	test_tb013_negative_acceleration_does_not_crash_or_produce_nan()
	test_tb013_negative_gravity_does_not_crash_or_produce_nan()
	test_tb013_negative_friction_does_not_crash_or_produce_nan()

	print("")
	print("  Results: " + str(_pass_count) + " passed, " + str(_fail_count) + " failed")
	return _fail_count
