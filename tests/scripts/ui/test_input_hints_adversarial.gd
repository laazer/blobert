func run_all() -> int:
	print("--- test_input_hints_adversarial.gd ---")
	_pass_count = 0
	_fail_count = 0

	# Group A: global toggle determinism and robustness
	test_input_hints_toggle_sequence_deterministic_across_runs()
	test_input_hints_toggle_changes_affect_existing_scenes_next_frame()
	test_input_hints_stress_repeated_scene_load_free_under_toggling()

	# Group B: infection input hint parenting / layout robustness
	test_infection_input_hints_not_parented_under_dynamic_world_nodes()

	# Group C: keyboard glyph coverage (CHECKPOINT)
	test_infection_move_hint_contains_keyboard_glyphs_for_horizontal_movement()
	test_infection_jump_hint_contains_keyboard_glyph_for_space()
	test_infection_detach_recall_hint_contains_keyboard_glyph_for_e()
	test_infection_absorb_hint_contains_keyboard_glyph_for_r()

	print("")
	print("  Results (adversarial InputHints): " + str(_pass_count) + " passed, " + str(_fail_count) + " failed")
	return _fail_count

