#
# test_input_hints_adversarial.gd
#
# Adversarial / edge-case tests for the input hint polish slice.
# Generated by Test Breaker Agent — 2026-03-05
#
# Scope:
#   - Global toggle robustness and determinism for InputHintsConfig across
#     core movement and infection-loop scenes.
#   - Dynamic response of existing scenes when the global toggle changes
#     after scene instantiation (no stale cached visibility).
#   - Additional layout and parenting checks for infection-loop input hints
#     to avoid coupling to moving physics nodes.
#   - Minimal keyboard glyph coverage for default PC bindings in infection
#     input hints (A/D, Space, E, R). # CHECKPOINT
#
# All tests are deterministic and purely structural/behavioral at the UI
# layer. They do not change simulation formulas; they only verify how the
# existing scenes and UI scripts reflect InputHintsConfig and layout rules.
#

class_name InputHintsAdversarialTests
extends Object

const EPSILON: float = 1e-4

var _pass_count: int = 0
var _fail_count: int = 0


# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

func _approx_eq(a: float, b: float) -> bool:
	return abs(a - b) < EPSILON


func _pass(test_name: String) -> void:
	_pass_count += 1
	print("  PASS: " + test_name)


func _fail(test_name: String, message: String) -> void:
	_fail_count += 1
	print("  FAIL: " + test_name + " — " + message)


func _assert_true(condition: bool, test_name: String) -> void:
	if condition:
		_pass(test_name)
	else:
		_fail(test_name, "expected true, got false")


func _assert_false(condition: bool, test_name: String) -> void:
	if not condition:
		_pass(test_name)
	else:
		_fail(test_name, "expected false, got true")


func _assert_approx(a: float, b: float, test_name: String) -> void:
	if _approx_eq(a, b):
		_pass(test_name)
	else:
		_fail(test_name, "got " + str(a) + " expected " + str(b) + " (delta " + str(abs(a - b)) + ")")


func _load_core_scene() -> Node:
	var packed: PackedScene = load("res://scenes/levels/test_movement.tscn") as PackedScene
	if packed == null:
		_fail("adv_input_hints_core_scene_load", "could not load res://scenes/levels/test_movement.tscn")
		return null
	var inst: Node = packed.instantiate()
	if inst == null:
		_fail("adv_input_hints_core_scene_instantiate", "instantiate() returned null for test_movement.tscn")
		return null
	return inst


func _load_infection_scene() -> Node:
	var packed: PackedScene = load("res://scenes/levels/test_infection_loop.tscn") as PackedScene
	if packed == null:
		_fail("adv_input_hints_infection_scene_load", "could not load res://scenes/levels/test_infection_loop.tscn")
		return null
	var inst: Node = packed.instantiate()
	if inst == null:
		_fail("adv_input_hints_infection_scene_instantiate", "instantiate() returned null for test_infection_loop.tscn")
		return null
	return inst


func _get_input_hints_config() -> Node:
	var tree: SceneTree = Engine.get_main_loop() as SceneTree
	if tree == null or tree.root == null:
		return null
	return tree.root.get_node_or_null("InputHintsConfig")


func _find_infection_ui(root: Node) -> CanvasLayer:
	if root == null:
		return null
	var infection_ui: CanvasLayer = root.get_node_or_null("InfectionUI") as CanvasLayer
	return infection_ui


func _labels_with_text_under_infection_ui(root: Node, needle: String) -> Array:
	var matches: Array = []
	var infection_ui: CanvasLayer = _find_infection_ui(root)
	if infection_ui == null:
		return matches
	var lower_needle: String = needle.to_lower()
	for child in infection_ui.find_children("*", "Label", true, false):
		var label := child as Label
		if label == null:
			continue
		if lower_needle in label.text.to_lower():
			matches.append(label)
	return matches


func _collect_infection_hint_labels(root: Node) -> Array:
	var keywords: Array = ["move", "jump", "detach", "recall", "absorb"]
	var result: Array = []
	for keyword in keywords:
		var labels: Array = _labels_with_text_under_infection_ui(root, keyword)
		for label in labels:
			if not result.has(label):
				result.append(label)
	return result


func _has_dynamic_world_ancestor(node: Node) -> bool:
	var current: Node = node
	while current != null:
		if current is CharacterBody2D or current is RigidBody2D or current is StaticBody2D:
			return true
		current = current.get_parent()
	return false


func _get_core_hint_labels(root: Node) -> Array:
	var labels: Array = []
	if root == null:
		return labels
	var hints_root: Control = root.get_node_or_null("UI/Hints") as Control
	if hints_root == null:
		return labels

	var move_hint: Label = hints_root.get_node_or_null("MoveHint") as Label
	var jump_hint: Label = hints_root.get_node_or_null("JumpHint") as Label
	var detach_hint: Label = hints_root.get_node_or_null("DetachHint") as Label

	if move_hint != null:
		labels.append(move_hint)
	if jump_hint != null:
		labels.append(jump_hint)
	if detach_hint != null:
		labels.append(detach_hint)

	return labels


func _visible_hint_counts_for_toggle_sequence(sequence: Array[bool]) -> Dictionary:
	var config: Node = _get_input_hints_config()
	if config == null:
		_fail("adv_input_hints_config_missing_for_sequence", "InputHintsConfig autoload not found at /root/InputHintsConfig for sequence test")
		return {}

	if not ("input_hints_enabled" in config):
		_fail("adv_input_hints_config_missing_flag_for_sequence", "InputHintsConfig must expose boolean property input_hints_enabled for sequence test")
		return {}

	var core_counts: Array[int] = []
	var infection_counts: Array[int] = []

	for enabled in sequence:
		config.input_hints_enabled = enabled

		var core_root: Node = _load_core_scene()
		if core_root != null:
			var core_labels: Array = _get_core_hint_labels(core_root)
			var core_visible_count: int = 0
			for label in core_labels:
				if (label as Label).visible:
					core_visible_count += 1
			core_counts.append(core_visible_count)
			core_root.free()

		var infection_root: Node = _load_infection_scene()
		if infection_root != null:
			var keywords: Array = ["move", "jump", "detach", "recall", "absorb"]
			var infection_visible_count: int = 0
			for keyword in keywords:
				var labels: Array = _labels_with_text_under_infection_ui(infection_root, keyword)
				for label in labels:
					if (label as Label).visible:
						infection_visible_count += 1
			infection_counts.append(infection_visible_count)
			infection_root.free()

	return {
		"core": core_counts,
		"infection": infection_counts,
	}


func _arrays_equal_int(a: Array[int], b: Array[int]) -> bool:
	if a.size() != b.size():
		return false
	for i in range(a.size()):
		if a[i] != b[i]:
			return false
	return true


func _any_label_visible(labels: Array) -> bool:
	for label in labels:
		if (label as Label).visible:
			return true
	return false


# ---------------------------------------------------------------------------
# GROUP A: Global toggle determinism and robustness
# ---------------------------------------------------------------------------

func test_input_hints_toggle_sequence_deterministic_across_runs() -> void:
	var sequence: Array[bool] = [
		true, true, false, false, true,
		false, true, false, true, true,
	]

	var first: Dictionary = _visible_hint_counts_for_toggle_sequence(sequence)
	var second: Dictionary = _visible_hint_counts_for_toggle_sequence(sequence)
	if first.is_empty() or second.is_empty():
		return

	var core_equal: bool = _arrays_equal_int(
		first["core"] as Array[int],
		second["core"] as Array[int]
	)
	var infection_equal: bool = _arrays_equal_int(
		first["infection"] as Array[int],
		second["infection"] as Array[int]
	)

	_assert_true(core_equal and infection_equal,
		"adv_input_hints_toggle_sequence_deterministic — visible hint counts for core and infection scenes are deterministic for a fixed toggle sequence")


func test_input_hints_toggle_changes_affect_existing_scenes_next_frame() -> void:
	var config: Node = _get_input_hints_config()
	if config == null:
		_fail("adv_input_hints_config_missing_for_dynamic_toggle", "InputHintsConfig autoload not found at /root/InputHintsConfig for dynamic toggle test")
		return

	if not ("input_hints_enabled" in config):
		_fail("adv_input_hints_config_missing_flag_for_dynamic_toggle", "InputHintsConfig must expose boolean property input_hints_enabled for dynamic toggle test")
		return

	# Start with hints enabled and scenes instantiated.
	config.input_hints_enabled = true

	var core_root: Node = _load_core_scene()
	var infection_root: Node = _load_infection_scene()
	if core_root == null or infection_root == null:
		if core_root != null:
			core_root.free()
		if infection_root != null:
			infection_root.free()
		return

	var core_labels_enabled: Array = _get_core_hint_labels(core_root)
	var infection_labels_enabled: Array = _collect_infection_hint_labels(infection_root)

	var any_core_visible_before: bool = _any_label_visible(core_labels_enabled)
	var any_infection_visible_before: bool = _any_label_visible(infection_labels_enabled)

	# Now disable hints and allow one frame for UI scripts to react.
	config.input_hints_enabled = false

	var core_ui: CanvasLayer = core_root.get_node_or_null("UI") as CanvasLayer
	if core_ui != null and core_ui.has_method("_process"):
		core_ui.call("_process", 0.016)

	var infection_ui: CanvasLayer = _find_infection_ui(infection_root)
	if infection_ui != null and infection_ui.has_method("_process"):
		infection_ui.call("_process", 0.016)

	var core_labels_disabled: Array = _get_core_hint_labels(core_root)
	var infection_labels_disabled: Array = _collect_infection_hint_labels(infection_root)

	var any_core_visible_after: bool = _any_label_visible(core_labels_disabled)
	var any_infection_visible_after: bool = _any_label_visible(infection_labels_disabled)

	_assert_true(any_core_visible_before,
		"adv_input_hints_core_visible_before_disable — at least one core hint is visible before dynamic disable")
	_assert_true(any_infection_visible_before,
		"adv_input_hints_infection_visible_before_disable — at least one infection hint is visible before dynamic disable")

	_assert_false(any_core_visible_after,
		"adv_input_hints_core_hidden_after_dynamic_disable — all core hints become hidden within one frame of disabling global toggle")
	_assert_false(any_infection_visible_after,
		"adv_input_hints_infection_hidden_after_dynamic_disable — all infection hints become hidden within one frame of disabling global toggle")

	core_root.free()
	infection_root.free()


func test_input_hints_stress_repeated_scene_load_free_under_toggling() -> void:
	var config: Node = _get_input_hints_config()
	if config == null:
		_fail("adv_input_hints_config_missing_for_stress", "InputHintsConfig autoload not found at /root/InputHintsConfig for stress test")
		return

	if not ("input_hints_enabled" in config):
		_fail("adv_input_hints_config_missing_flag_for_stress", "InputHintsConfig must expose boolean property input_hints_enabled for stress test")
		return

	var iterations: int = 10
	var all_ok: bool = true

	for i in range(iterations):
		config.input_hints_enabled = (i % 2 == 0)

		var core_root: Node = _load_core_scene()
		var infection_root: Node = _load_infection_scene()
		if core_root == null or infection_root == null:
			all_ok = false
			if core_root != null:
				core_root.free()
			if infection_root != null:
				infection_root.free()
			break

		var core_labels: Array = _get_core_hint_labels(core_root)
		var infection_labels: Array = _collect_infection_hint_labels(infection_root)

		# If enabled, at least one hint should be visible somewhere; if disabled,
		# no hints should be visible.
		var any_core_visible: bool = _any_label_visible(core_labels)
		var any_infection_visible: bool = _any_label_visible(infection_labels)

		if config.input_hints_enabled:
			if not (any_core_visible or any_infection_visible):
				all_ok = false
		else:
			if any_core_visible or any_infection_visible:
				all_ok = false

		core_root.free()
		infection_root.free()

	_assert_true(all_ok,
		"adv_input_hints_stress_load_free_under_toggling — repeated scene load/free under toggle changes behaves consistently and respects toggle state")


# ---------------------------------------------------------------------------
# GROUP B: Layout and parenting robustness for infection input hints
# ---------------------------------------------------------------------------

func test_infection_input_hints_not_parented_under_dynamic_world_nodes() -> void:
	var root: Node = _load_infection_scene()
	if root == null:
		return

	var labels: Array = _collect_infection_hint_labels(root)
	if labels.is_empty():
		_fail("adv_input_hints_infection_labels_present_for_parenting_checks",
			"No infection input hint labels found for parenting checks")
		root.free()
		return

	var any_under_dynamic_world: bool = false
	for label in labels:
		if _has_dynamic_world_ancestor(label):
			any_under_dynamic_world = true
			break

	_assert_false(any_under_dynamic_world,
		"adv_input_hints_infection_not_under_dynamic_world_nodes — infection input hint labels are not children of moving physics bodies")

	root.free()


