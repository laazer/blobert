func _find_first_label_with_keyword(root: Node, keyword: String) -> Label:
	var labels: Array = _labels_with_text_under_infection_ui(root, keyword)
	if labels.is_empty():
		return null
	return labels[0] as Label


func test_infection_move_hint_contains_keyboard_glyphs_for_horizontal_movement() -> void:
	# CHECKPOINT:
	#   Would have asked: Should the infection-loop move hint text explicitly
	#   include the default keyboard glyphs "A/D" for horizontal movement, or
	#   is generic "move left/right" wording sufficient?
	#   Assumption made: For PC default bindings, the move hint must encode
	#   the "A/D" glyph pairing to keep UI consistent with Milestone 1 core
	#   movement hints and HumanPlayableCore adversarial InputMap tests.
	#   Confidence: Medium.
	var root: Node = _load_infection_scene()
	if root == null:
		return

	var label: Label = _find_first_label_with_keyword(root, "move")
	if label == null:
		_fail("adv_input_hints_infection_move_label_missing_for_glyphs",
			"No infection input hint label found containing 'move' for glyph coverage test")
		root.free()
		return

	var text: String = label.text
	var has_ad_pair: bool = ("A/D" in text) or ("A / D" in text)
	_assert_true(has_ad_pair,
		"adv_input_hints_infection_move_hint_has_ad_glyphs — move hint text includes 'A/D' keyboard glyphs for horizontal movement") # CHECKPOINT

	root.free()


