func _assert_hud_stable_for_constant_hp(load_scene_func: Callable, scene_name: String) -> void:
	var ctx: Dictionary = _prepare_scene_for_hud(load_scene_func, scene_name)
	if ctx.is_empty():
		return

	var root: Node = ctx["root"]
	var player: PlayerController = ctx["player"]
	var hud: CanvasLayer = ctx["hud"]
	var hp_label: Label = ctx["hp_label"]
	var hp_bar: Range = ctx["hp_bar"]

	_configure_player_hp_and_chunk(player, 73.0, true)
	hud._process(0.016)

	var initial_label_text: String = hp_label.text
	var initial_bar_value: float = hp_bar.value

	for _i in range(10):
		hud._process(0.016)

	var final_label_text: String = hp_label.text
	var final_bar_value: float = hp_bar.value

	_assert_true(initial_label_text == final_label_text,
		scene_name + "_adv_hud_label_stable_under_constant_hp — HP label text remains stable over repeated _process() calls at fixed HP")
	_assert_approx(initial_bar_value, final_bar_value,
		scene_name + "_adv_hud_bar_stable_under_constant_hp — HP bar value remains stable over repeated _process() calls at fixed HP")

	root.free()


func test_core_hud_stable_under_constant_hp() -> void:
	_assert_hud_stable_for_constant_hp(_load_core_scene, "core")


func test_infection_hud_stable_under_constant_hp() -> void:
	_assert_hud_stable_for_constant_hp(_load_infection_scene, "infection")


# ---------------------------------------------------------------------------
# GROUP C: Detach / recall-style HP and chunk state sequences
# ---------------------------------------------------------------------------

func _assert_detach_and_recall_style_sequence(load_scene_func: Callable, scene_name: String) -> void:
	var ctx: Dictionary = _prepare_scene_for_hud(load_scene_func, scene_name)
	if ctx.is_empty():
		return

	var root: Node = ctx["root"]
	var player: PlayerController = ctx["player"]
	var hud: CanvasLayer = ctx["hud"]
	var hp_label: Label = ctx["hp_label"]
	var chunk_label: Label = ctx["chunk_label"]
	var hp_bar: Range = ctx["hp_bar"]

	# Baseline: full HP, chunk attached.
	_configure_player_hp_and_chunk(player, 100.0, true)
	hud._process(0.016)
	var bar_full: float = hp_bar.value

	# Simulate detach: reduced HP, chunk detached.
	_configure_player_hp_and_chunk(player, 70.0, false)
	hud._process(0.016)
	var bar_detached: float = hp_bar.value
	var chunk_text_detached: String = chunk_label.text

	_assert_true(_label_contains_number(hp_label, 70.0),
		scene_name + "_adv_hud_hp_label_shows_detach_hp — HP label text updates to show reduced HP after detach-style state")
	_assert_true(chunk_text_detached == "Chunk: Detached",
		scene_name + "_adv_hud_chunk_label_exact_detached_text — ChunkStatusLabel shows exact 'Chunk: Detached' text when has_chunk=false") # CHECKPOINT

	# Simulate recall: higher HP than detached, chunk reattached.
	_configure_player_hp_and_chunk(player, 85.0, true)
	hud._process(0.016)
	var bar_recalled: float = hp_bar.value
	var chunk_text_recalled: String = chunk_label.text

	_assert_true(_label_contains_number(hp_label, 85.0),
		scene_name + "_adv_hud_hp_label_shows_recall_hp — HP label text updates to show restored HP after recall-style state")
	_assert_true(chunk_text_recalled == "Chunk: Attached",
		scene_name + "_adv_hud_chunk_label_exact_attached_text — ChunkStatusLabel shows exact 'Chunk: Attached' text when has_chunk=true") # CHECKPOINT

	# HP bar must move down on detach and then partially back up on recall,
	# without exceeding the original full-HP bar value.
	var bar_sequence_ok: bool = (
		bar_full > bar_detached + EPSILON
		and bar_recalled > bar_detached + EPSILON
		and bar_full >= bar_recalled - EPSILON
	)
	_assert_true(bar_sequence_ok,
		scene_name + "_adv_hud_hp_bar_sequence_detach_recall — HP bar decreases on detach and increases again on recall without overshooting baseline")

	root.free()


func test_core_hud_detach_and_recall_style_sequence() -> void:
	_assert_detach_and_recall_style_sequence(_load_core_scene, "core")


func test_infection_hud_detach_and_recall_style_sequence() -> void:
	_assert_detach_and_recall_style_sequence(_load_infection_scene, "infection")


