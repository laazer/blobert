#
# test_hp_and_chunk_hud_adversarial.gd
#
# Adversarial / edge-case tests for the HP and chunk HUD slice.
# Generated by Test Breaker Agent — 2026-03-04
#
# Scope:
#   - Stronger monotonicity checks for HP bar across multiple HP levels.
#   - Stability and determinism of HUD under repeated _process() calls.
#   - Detach/recall-style HP + chunk state sequences and exact chunk label text.
#   - Scene-level HUD CanvasLayer identity assertions for core vs. infection scenes.
#
# All tests are deterministic and purely structural/behavioral at the HUD layer.
# They do not change simulation formulas; they only verify how existing UI
# scripts reflect PlayerController._current_state fields and scene wiring.
#

class_name HpAndChunkHudAdversarialTests
extends Object

const EPSILON: float = 1e-4

var _pass_count: int = 0
var _fail_count: int = 0


# ---------------------------------------------------------------------------
# Helpers (mirroring contracts from test_hp_and_chunk_hud.gd)
# ---------------------------------------------------------------------------

func _approx_eq(a: float, b: float) -> bool:
	return abs(a - b) < EPSILON


func _pass(test_name: String) -> void:
	_pass_count += 1
	print("  PASS: " + test_name)


func _fail(test_name: String, message: String) -> void:
	_fail_count += 1
	print("  FAIL: " + test_name + " — " + message)


func _assert_true(condition: bool, test_name: String) -> void:
	if condition:
		_pass(test_name)
	else:
		_fail(test_name, "expected true, got false")


func _assert_false(condition: bool, test_name: String) -> void:
	if not condition:
		_pass(test_name)
	else:
		_fail(test_name, "expected false, got true")


func _assert_approx(a: float, b: float, test_name: String) -> void:
	if _approx_eq(a, b):
		_pass(test_name)
	else:
		_fail(test_name, "got " + str(a) + " expected " + str(b) + " (delta " + str(abs(a - b)) + ")")


func _load_core_scene() -> Node:
	var packed: PackedScene = load("res://scenes/levels/test_movement.tscn") as PackedScene
	if packed == null:
		_fail("adv_hud_core_scene_load", "could not load res://scenes/levels/test_movement.tscn")
		return null
	var inst: Node = packed.instantiate()
	if inst == null:
		_fail("adv_hud_core_scene_instantiate", "instantiate() returned null for test_movement.tscn")
		return null
	return inst


func _load_infection_scene() -> Node:
	var packed: PackedScene = load("res://scenes/levels/test_infection_loop.tscn") as PackedScene
	if packed == null:
		_fail("adv_hud_infection_scene_load", "could not load res://scenes/levels/test_infection_loop.tscn")
		return null
	var inst: Node = packed.instantiate()
	if inst == null:
		_fail("adv_hud_infection_scene_instantiate", "instantiate() returned null for test_infection_loop.tscn")
		return null
	return inst


func _find_player(root: Node) -> PlayerController:
	if root == null:
		return null
	var player: PlayerController = root.get_node_or_null("Player") as PlayerController
	return player


func _find_hud_layer_with_hp(root: Node) -> CanvasLayer:
	if root == null:
		return null
	for candidate in root.find_children("*", "CanvasLayer", true, false):
		var layer := candidate as CanvasLayer
		if layer == null:
			continue
		var hp_label: Label = layer.get_node_or_null("HPLabel") as Label
		if hp_label == null:
			var matches: Array = layer.find_children("HPLabel", "Label", true, false)
			if matches.size() > 0:
				hp_label = matches[0] as Label
		if hp_label != null:
			return layer
	return null


func _get_hp_label(hud: CanvasLayer) -> Label:
	if hud == null:
		return null
	var label: Label = hud.get_node_or_null("HPLabel") as Label
	if label != null:
		return label
	var matches: Array = hud.find_children("HPLabel", "Label", true, false)
	if matches.size() > 0:
		return matches[0] as Label
	return null


func _get_chunk_label(hud: CanvasLayer) -> Label:
	if hud == null:
		return null
	var label: Label = hud.get_node_or_null("ChunkStatusLabel") as Label
	if label != null:
		return label
	var matches: Array = hud.find_children("ChunkStatusLabel", "Label", true, false)
	if matches.size() > 0:
		return matches[0] as Label
	return null


func _get_hp_bar(hud: CanvasLayer) -> Range:
	if hud == null:
		return null
	var bar_node: Node = hud.get_node_or_null("HPBar")
	if bar_node != null and bar_node is Range:
		return bar_node as Range

	for child in hud.find_children("*", "", true, false):
		var range_node := child as Range
		if range_node != null:
			return range_node
	return null


func _label_contains_number(label: Label, value: float) -> bool:
	if label == null:
		return false
	var text_lower: String = label.text.to_lower()
	var expected_int_text: String = str(int(round(value)))
	return expected_int_text in text_lower


func _configure_player_hp_and_chunk(player: PlayerController, hp_value: float, has_chunk: bool) -> void:
	if player == null:
		return
	player._current_state.current_hp = hp_value
	player._current_state.has_chunk = has_chunk


func _attach_player_to_hud_if_supported(hud: CanvasLayer, player: PlayerController) -> void:
	if hud == null or player == null:
		return
	if "_player" in hud:
		hud._player = player


func _prepare_scene_for_hud(load_scene_func: Callable, scene_name: String) -> Dictionary:
	var root: Node = load_scene_func.call() as Node
	if root == null:
		return {}

	var player: PlayerController = _find_player(root)
	if player == null:
		_fail(scene_name + "_adv_hud_player_exists", "Player node is not a PlayerController in " + scene_name + " scene")
		root.free()
		return {}

	player._ready()

	var hud: CanvasLayer = _find_hud_layer_with_hp(root)
	if hud == null:
		_fail(scene_name + "_adv_hud_layer_missing", "HUD CanvasLayer with HPLabel not found; cannot run adversarial HUD tests")
		root.free()
		return {}

	_attach_player_to_hud_if_supported(hud, player)

	var hp_label: Label = _get_hp_label(hud)
	var chunk_label: Label = _get_chunk_label(hud)
	var hp_bar: Range = _get_hp_bar(hud)

	if hp_label == null or chunk_label == null or hp_bar == null:
		_fail(scene_name + "_adv_hud_elements_missing",
			"HPLabel, ChunkStatusLabel, and HP bar must all exist to run adversarial HUD tests")
		root.free()
		return {}

	return {
		"root": root,
		"player": player,
		"hud": hud,
		"hp_label": hp_label,
		"chunk_label": chunk_label,
		"hp_bar": hp_bar,
	}


# ---------------------------------------------------------------------------
# GROUP A: HP bar monotonicity and numeric label coverage
# ---------------------------------------------------------------------------

func _assert_monotonic_hp_bar_three_points(load_scene_func: Callable, scene_name: String) -> void:
	var ctx: Dictionary = _prepare_scene_for_hud(load_scene_func, scene_name)
	if ctx.is_empty():
		return

	var root: Node = ctx["root"]
	var player: PlayerController = ctx["player"]
	var hud: CanvasLayer = ctx["hud"]
	var hp_label: Label = ctx["hp_label"]
	var hp_bar: Range = ctx["hp_bar"]

	var hp_values: Array = [100.0, 50.0, 0.0]
	var bar_values: Array[float] = []
	var all_labels_ok: bool = true

	for hp in hp_values:
		_configure_player_hp_and_chunk(player, hp, true)
		hud._process(0.016)

		bar_values.append(float(hp_bar.value))
		if not _label_contains_number(hp_label, hp):
			all_labels_ok = false

	_assert_true(all_labels_ok,
		scene_name + "_adv_hud_hp_label_covers_100_50_0 — HP label text contains 100, 50, and 0 for representative HP values")

	if bar_values.size() == 3:
		var full: float = bar_values[0]
		var mid: float = bar_values[1]
		var zero: float = bar_values[2]

		var strictly_monotonic: bool = (
			full > mid + EPSILON
			and mid > zero + EPSILON
		)
		_assert_true(strictly_monotonic,
			scene_name + "_adv_hud_hp_bar_strictly_decreases_100_50_0 — HP bar value strictly decreases as HP decreases from 100→50→0")

	root.free()


func test_core_hud_hp_bar_and_label_monotonic_three_points() -> void:
	_assert_monotonic_hp_bar_three_points(_load_core_scene, "core")


func test_infection_hud_hp_bar_and_label_monotonic_three_points() -> void:
	_assert_monotonic_hp_bar_three_points(_load_infection_scene, "infection")


