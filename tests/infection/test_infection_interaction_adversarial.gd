# ===========================================================================
# [infection_interaction] TB-II-003 — Stress: many ESMs, absorb alternating
#
# VULNERABILITY: Primary suite uses two enemies. Cross-entity interference or
# shared state could appear only with many instances. This test absorbs every
# other of 20 infected ESMs and asserts isolation and correct total count.
# ===========================================================================

func test_tb_ii_003_many_esms_absorb_alternating_isolation() -> void:
	var arr: Array = _require_infection_modules()
	var inv = arr[0]
	var resolver = arr[1]
	if inv == null or resolver == null:
		_fail("tb_ii_003_skip", "scripts missing; skipping")
		return
	var esms: Array[EnemyStateMachine] = []
	for i in 20:
		esms.append(_make_esm())
		_drive_to_infected(esms[i])
	# Absorb only even-indexed
	for i in 20:
		if i % 2 == 0:
			resolver.resolve_absorb(esms[i], inv)
	_assert_eq_int(10, inv.get_granted_count(), "tb_ii_003_ten_grants — exactly 10 absorbs grant 10 mutations")
	for i in 20:
		if i % 2 == 0:
			_assert_eq_string("dead", _state_of(esms[i]), "tb_ii_003_even_dead_" + str(i))
		else:
			_assert_eq_string("infected", _state_of(esms[i]), "tb_ii_003_odd_still_infected_" + str(i))
		_assert_true(_state_allowed(_state_of(esms[i])), "tb_ii_003_allowed_" + str(i) + " — state in allowed set")


# ===========================================================================
# [infection_interaction] TB-II-004 — Order independence: absorb A then B vs B then A
#
# VULNERABILITY: Total mutation count and final ESM states should be
# independent of the order in which two infected enemies are absorbed.
# ===========================================================================

func test_tb_ii_004_absorb_order_independence() -> void:
	var arr: Array = _require_infection_modules()
	var inv = arr[0]
	var resolver = arr[1]
	if inv == null or resolver == null:
		_fail("tb_ii_004_skip", "scripts missing; skipping")
		return
	var a: EnemyStateMachine = _make_esm()
	var b: EnemyStateMachine = _make_esm()
	_drive_to_infected(a)
	_drive_to_infected(b)
	resolver.resolve_absorb(a, inv)
	resolver.resolve_absorb(b, inv)
	var count_ab: int = inv.get_granted_count()
	# Reset and do B then A with fresh inventory
	var inv2 = _load_mutation_inventory_script()
	if inv2 == null:
		_fail("tb_ii_004_inv2", "could not create second inventory; skipping")
		return
	var inv_b: Object = inv2.new()
	var a2: EnemyStateMachine = _make_esm()
	var b2: EnemyStateMachine = _make_esm()
	_drive_to_infected(a2)
	_drive_to_infected(b2)
	resolver.resolve_absorb(b2, inv_b)
	resolver.resolve_absorb(a2, inv_b)
	var count_ba: int = inv_b.get_granted_count()
	_assert_eq_int(2, count_ab, "tb_ii_004_ab_two — A then B grants 2")
	_assert_eq_int(2, count_ba, "tb_ii_004_ba_two — B then A grants 2")
	_assert_eq_string("dead", _state_of(a), "tb_ii_004_a_dead")
	_assert_eq_string("dead", _state_of(b), "tb_ii_004_b_dead")
	_assert_eq_string("dead", _state_of(a2), "tb_ii_004_a2_dead")
	_assert_eq_string("dead", _state_of(b2), "tb_ii_004_b2_dead")


