# ===========================================================================
# [infection_interaction] TB-II-001 — get_granted_count never negative
#
# VULNERABILITY: Primary suite does not assert that get_granted_count() stays
# non-negative under any sequence. A buggy implementation could return negative
# after invalid operations or internal overflow.
# ===========================================================================

func test_tb_ii_001_granted_count_never_negative() -> void:
	var arr: Array = _require_infection_modules()
	var inv = arr[0]
	if inv == null:
		_fail("tb_ii_001_skip", "MutationInventory script missing; skipping")
		return
	_assert_true(inv.get_granted_count() >= 0, "tb_ii_001_initial_non_negative — initial count >= 0")
	# Absorb-only (no grants) should not decrease any internal counter
	var resolver = arr[1]
	if resolver != null:
		var esm: EnemyStateMachine = _make_esm()
		resolver.resolve_absorb(esm, inv)
		_assert_true(inv.get_granted_count() >= 0, "tb_ii_001_after_idle_absorb_non_negative — count >= 0 after absorb on idle")
		_drive_to_weakened(esm)
		resolver.resolve_absorb(esm, inv)
		_assert_true(inv.get_granted_count() >= 0, "tb_ii_001_after_weakened_absorb_non_negative — count >= 0 after absorb on weakened")


