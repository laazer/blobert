{
  "threshold": 10,
  "minTokens": 10,
  "minLines": 10,
  "reporters": ["json", "text"],
  "output": ".",
  "exclude": [
    "**/.venv/**",
    "**/venv/**",
    "**/node_modules/**",
    "**/.git/**",
    "**/.godot/**",
    "**/dist/**",
    "**/build/**",
    "**/.next/**",
    "**/out/**",
    "**/reference_projects/**",
    "**/__pycache__/**",
    "**/*.glb",
    "**/*_export.png",
    "**/*_bake.png",
    "**/*_export.jpg",
    "**/*.lock",
    "**/.DS_Store",
    "**/Thumbs.db",
    "project_board/**",
    "asset_generation/python/animated_exports/**",
    "asset_generation/python/player_exports/**",
    "asset_generation/python/tests/materials/**/*.png",
    "asset_generation/python/tests/utils/**/*.png"
  ],
  "ignoreCase": true,
  "ignoreComments": false,
  "skipBinaryFiles": true,
  "languages": [
    "python",
    "javascript",
    "typescript",
    "gdscript",
    "json",
    "yaml",
    "toml",
    "html",
    "css"
  ],
  "format": ["json"]
}
